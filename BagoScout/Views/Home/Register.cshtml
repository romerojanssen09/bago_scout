@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - BagoScout</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-purple': '#6C63FF',
                        'dark-navy': '#1C2B53',
                        'medium-gray': '#8D94A8',
                        'light-bg': '#F0F4FF',
                    }
                }
            }
        }
    </script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background: white;
            min-height: 100vh;
        }
    </style>
    <link rel="stylesheet" href="~/css/register.css" />
</head>
<body class="register-page">
    <div class="register-container">
        <button class="close-btn" onclick="window.location.href='/'">
            <i class="fas fa-times"></i>
        </button>
        
        <div class="register-header">
            <h1>Create Account</h1>
            <p>Join BagoScout today</p>
        </div>
        
        <!-- Step Indicator -->
        <div class="step-indicator">
            <div class="step active" id="stepIndicator1">
                <div class="step-number">1</div>
                <div class="step-label">Type</div>
            </div>
            <div class="step-line"></div>
            <div class="step" id="stepIndicator2">
                <div class="step-number">2</div>
                <div class="step-label">Account</div>
            </div>
            <div class="step-line"></div>
            <div class="step" id="stepIndicator3">
                <div class="step-number">3</div>
                <div class="step-label">Verify</div>
            </div>
            <div class="step-line"></div>
            <div class="step" id="stepIndicator4">
                <div class="step-number">4</div>
                <div class="step-label">ID</div>
            </div>
            <div class="step-line"></div>
            <div class="step" id="stepIndicator5">
                <div class="step-number">5</div>
                <div class="step-label">Skills</div>
            </div>
        </div>
        
        <!-- Step 1: User Type Selection -->
        <div id="step1" class="step-content active">
            <h3 class="step-title">I am a...</h3>
            <div class="user-type-grid">
                <div class="user-type-card" onclick="selectUserType('seeker')">
                    <div class="user-type-icon">
                        <i class="fas fa-user"></i>
                    </div>
                    <div class="user-type-title">Job Seeker</div>
                    <div class="user-type-desc">Looking for opportunities</div>
                </div>
                <div class="user-type-card" onclick="selectUserType('employer')">
                    <div class="user-type-icon">
                        <i class="fas fa-briefcase"></i>
                    </div>
                    <div class="user-type-title">Employer</div>
                    <div class="user-type-desc">Hiring talent</div>
                </div>
            </div>
        </div>
        
        <!-- Step 2: Account Creation -->
        <div id="step2" class="step-content">
            <h3 class="step-title">Create Your Account</h3>
            <div class="form-group">
                <label>First Name</label>
                <input type="text" id="regFirstName" class="form-input" placeholder="Enter first name" required>
            </div>
            <div class="form-group">
                <label>Last Name</label>
                <input type="text" id="regLastName" class="form-input" placeholder="Enter last name" required>
            </div>
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" id="regEmail" class="form-input" placeholder="Enter your email" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <div class="password-wrapper">
                    <input type="password" id="regPassword" class="form-input" placeholder="Create password" required>
                    <button type="button" class="password-toggle" onclick="togglePassword('regPassword')">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <div class="password-requirements">
                    <div class="requirement" id="req-length">
                        <i class="fas fa-circle"></i>
                        <span>At least 8 characters</span>
                    </div>
                    <div class="requirement" id="req-capital">
                        <i class="fas fa-circle"></i>
                        <span>One uppercase letter</span>
                    </div>
                    <div class="requirement" id="req-number">
                        <i class="fas fa-circle"></i>
                        <span>One number</span>
                    </div>
                    <div class="requirement" id="req-special">
                        <i class="fas fa-circle"></i>
                        <span>One special character</span>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <label>Confirm Password</label>
                <div class="password-wrapper">
                    <input type="password" id="regConfirmPassword" class="form-input" placeholder="Confirm password" required>
                    <button type="button" class="password-toggle" onclick="togglePassword('regConfirmPassword')">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <div class="password-match" id="password-match"></div>
            </div>
        </div>
        
        <!-- Step 3: Email Verification -->
        <div id="step3" class="step-content">
            <h3 class="step-title">Verify Your Email</h3>
            <p class="step-subtitle">Enter the 6-digit code sent to your email</p>
            <div class="verification-code">
                <input type="text" maxlength="1" id="code1" pattern="[0-9]">
                <input type="text" maxlength="1" id="code2" pattern="[0-9]">
                <input type="text" maxlength="1" id="code3" pattern="[0-9]">
                <input type="text" maxlength="1" id="code4" pattern="[0-9]">
                <input type="text" maxlength="1" id="code5" pattern="[0-9]">
                <input type="text" maxlength="1" id="code6" pattern="[0-9]">
            </div>
            <div class="resend-code">
                Didn't receive code? <button onclick="resendCode()">Resend</button>
            </div>
        </div>
        
        <!-- Step 4: Photo & ID Upload -->
        <div id="step4" class="step-content">
            <h3 class="step-title">Verification Documents</h3>
            
            <div style="margin-bottom: 30px;">
                <label class="upload-label">Capture Selfie</label>
                <div class="camera-container">
                    <video id="cameraVideo" autoplay></video>
                    <div id="selfiePreview" class="file-preview"></div>
                </div>
                <div class="camera-controls">
                    <button type="button" id="startCameraBtn" class="btn-camera btn-start-camera" onclick="startCamera()">
                        <i class="fas fa-camera"></i> Start Camera
                    </button>
                    <button type="button" id="captureBtn" class="btn-camera btn-capture" onclick="capturePhoto()" style="display: none;">
                        <i class="fas fa-camera"></i> Capture
                    </button>
                    <button type="button" id="retakeBtn" class="btn-camera btn-retake" onclick="retakePhoto()" style="display: none;">
                        <i class="fas fa-redo"></i> Retake
                    </button>
                </div>
            </div>
            
            <div>
                <label class="upload-label">Upload Valid ID</label>
                <div class="file-upload-area" onclick="uploadID()">
                    <div class="file-upload-icon"><i class="fas fa-id-card"></i></div>
                    <div class="file-upload-text">Click to upload ID</div>
                    <div class="file-upload-hint">Supported: JPG, PNG (Max 5MB)</div>
                </div>
                <input type="file" id="idUpload" accept="image/*" style="display: none;">
                <div id="idPreview" class="file-preview"></div>
            </div>
        </div>
        
        <!-- Step 5: Skills/Preferences -->
        <div id="step5" class="step-content">
            <div id="step5Content">
                <!-- Content will be dynamically loaded based on user type -->
            </div>
        </div>
        
        <!-- Navigation Buttons -->
        <div class="nav-buttons">
            <button type="button" id="backBtn" class="btn-back" onclick="previousStep()" style="display: none;">Back</button>
            <button type="button" id="nextBtn" class="btn-next" onclick="nextStep()">Next</button>
        </div>
        
        <div class="register-footer">
            Already have an account? <a href="/" onclick="event.preventDefault(); openLoginModal();">Log in</a>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-spinner">
            <div class="spinner"></div>
            <div class="loading-text">Sending verification code...</div>
            <div class="loading-subtext">Please wait a moment</div>
        </div>
    </div>

    <script src="~/js/register.js"></script>
</body>
</html>
