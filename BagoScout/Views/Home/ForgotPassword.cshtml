@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - BagoScout</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-purple': '#6C63FF',
                        'dark-navy': '#1C2B53',
                        'medium-gray': '#8D94A8',
                        'light-bg': '#F0F4FF',
                    }
                }
            }
        }
    </script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background: white;
            min-height: 100vh;
        }
    </style>
    <link rel="stylesheet" href="~/css/register.css" />
</head>
<body class="register-page">
    <div class="register-container">
        <!-- Close Button -->
        <button class="close-btn" onclick="window.location.href='/'">
            <i class="fas fa-times"></i>
        </button>
        
        <div class="register-header">
            <h1>Forgot Password</h1>
            <p>Recover your BagoScout account</p>
        </div>
        
        <!-- Step Indicator -->
        <div class="step-indicator">
            <div class="step active" id="stepIndicator1">
                <div class="step-number">1</div>
                <div class="step-label">Request OTP</div>
            </div>
            <div class="step-line"></div>
            <div class="step" id="stepIndicator2">
                <div class="step-number">2</div>
                <div class="step-label">Verify OTP</div>
            </div>
            <div class="step-line"></div>
            <div class="step" id="stepIndicator3">
                <div class="step-number">3</div>
                <div class="step-label">Reset Password</div>
            </div>
        </div>
        
        <!-- Step 1: Request OTP -->
        <div id="step1" class="step-content active">
            <h3 class="step-title">Enter Email Address</h3>
            <p class="step-subtitle text-center mb-6">Provide your registered email address to receive a verification code.</p>
            
            <div class="form-group max-w-md mx-auto">
                <label>Email Address</label>
                <input type="email" id="forgotEmail" class="form-input" placeholder="Enter your email" required>
                <div class="mt-4 p-3 bg-blue-50 border border-blue-100 rounded-lg flex items-start gap-3">
                    <i class="fas fa-info-circle text-blue-500 mt-0.5"></i>
                    <p class="text-xs text-blue-700 leading-relaxed font-medium">
                        Notice: We will send a 6-digit OTP code to this email address if it is registered in our system.
                    </p>
                </div>
            </div>
        </div>
        
        <!-- Step 2: Confirm OTP -->
        <div id="step2" class="step-content">
            <h3 class="step-title">Verify Your OTP</h3>
            <p class="step-subtitle">Enter the 6-digit code sent to your email</p>
            <div class="verification-code">
                <input type="text" maxlength="1" id="code1" pattern="[0-9]" inputmode="numeric">
                <input type="text" maxlength="1" id="code2" pattern="[0-9]" inputmode="numeric">
                <input type="text" maxlength="1" id="code3" pattern="[0-9]" inputmode="numeric">
                <input type="text" maxlength="1" id="code4" pattern="[0-9]" inputmode="numeric">
                <input type="text" maxlength="1" id="code5" pattern="[0-9]" inputmode="numeric">
                <input type="text" maxlength="1" id="code6" pattern="[0-9]" inputmode="numeric">
            </div>
            <div class="resend-code">
                Didn't receive code? <button onclick="resendCode()">Resend</button>
            </div>
        </div>
        
        <!-- Step 3: New and Confirm Password -->
        <div id="step3" class="step-content">
            <h3 class="step-title">Reset Your Password</h3>
            <p class="step-subtitle">Set a secure password for your account</p>
            
            <div class="max-w-md mx-auto">
                <div class="form-group">
                    <label>New Password</label>
                    <div class="password-wrapper">
                        <input type="password" id="resetPassword" class="form-input" placeholder="Create new password" required>
                        <button type="button" class="password-toggle" onclick="togglePassword('resetPassword')">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <div class="password-requirements">
                        <div class="requirement" id="req-length">
                            <i class="fas fa-circle"></i>
                            <span>At least 8 characters</span>
                        </div>
                        <div class="requirement" id="req-capital">
                            <i class="fas fa-circle"></i>
                            <span>One uppercase letter</span>
                        </div>
                        <div class="requirement" id="req-number">
                            <i class="fas fa-circle"></i>
                            <span>One number</span>
                        </div>
                        <div class="requirement" id="req-special">
                            <i class="fas fa-circle"></i>
                            <span>One special character</span>
                        </div>
                    </div>
                </div>
                
                <div class="form-group">
                    <label>Confirm Password</label>
                    <div class="password-wrapper">
                        <input type="password" id="resetConfirmPassword" class="form-input" placeholder="Confirm password" required>
                        <button type="button" class="password-toggle" onclick="togglePassword('resetConfirmPassword')">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                    <div class="password-match" id="password-match"></div>
                </div>
            </div>
        </div>
        
        <!-- Navigation Buttons -->
        <div class="nav-buttons max-w-md mx-auto">
            <button type="button" id="backBtn" class="btn-back" onclick="previousStep()" style="display: none;">Back</button>
            <button type="button" id="nextBtn" class="btn-next" onclick="nextStep()">Next</button>
        </div>
        
        <div class="register-footer">
            Remembered your password? <a href="/">Log in</a>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-spinner">
            <div class="spinner"></div>
            <div class="loading-text">Sending verification code...</div>
            <div class="loading-subtext">Please wait a moment</div>
        </div>
    </div>

    <script>
        let currentStep = 1;
        let forgotData = {
            email: '',
            code: '',
            password: ''
        };

        function showStep(step) {
            currentStep = step;
            
            // Hide all steps
            for (let i = 1; i <= 3; i++) {
                const stepContent = document.getElementById(`step${i}`);
                const stepIndicator = document.getElementById(`stepIndicator${i}`);
                
                if (stepContent) stepContent.classList.remove('active');
                if (stepIndicator) {
                    stepIndicator.classList.remove('active');
                    stepIndicator.classList.remove('completed');
                }
            }
            
            // Show current step
            const currentStepContent = document.getElementById(`step${step}`);
            const currentStepIndicator = document.getElementById(`stepIndicator${step}`);
            
            if (currentStepContent) currentStepContent.classList.add('active');
            if (currentStepIndicator) currentStepIndicator.classList.add('active');
            
            // Mark completed steps
            for (let i = 1; i < step; i++) {
                const indicator = document.getElementById(`stepIndicator${i}`);
                if (indicator) indicator.classList.add('completed');
            }
            
            updateNavigationButtons();
        }

        function updateNavigationButtons() {
            const backBtn = document.getElementById('backBtn');
            const nextBtn = document.getElementById('nextBtn');
            
            if (backBtn) {
                backBtn.style.display = currentStep === 1 ? 'none' : 'block';
            }
            
            if (nextBtn) {
                nextBtn.textContent = currentStep === 3 ? 'Reset Password' : 'Next';
            }
        }

        async function nextStep() {
            if (await validateCurrentStep()) {
                if (currentStep < 3) {
                    showStep(currentStep + 1);
                } else {
                    await completeReset();
                }
            }
        }

        function previousStep() {
            if (currentStep > 1) {
                showStep(currentStep - 1);
            }
        }

        async function validateCurrentStep() {
            switch(currentStep) {
                case 1:
                    const email = document.getElementById('forgotEmail').value.trim();
                    if (!email) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Email Required',
                            text: 'Please enter your email address',
                            confirmButtonColor: '#1C2B53'
                        });
                        return false;
                    }
                    
                    const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                    if (!emailRegex.test(email)) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Invalid Email',
                            text: 'Please enter a valid email address',
                            confirmButtonColor: '#1C2B53'
                        });
                        return false;
                    }

                    forgotData.email = email;
                    return await sendForgotPasswordOtp(email);

                case 2:
                    const code = getVerificationCode();
                    if (code.length !== 6) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Incomplete Code',
                            text: 'Please enter the complete 6-digit verification code',
                            confirmButtonColor: '#1C2B53'
                        });
                        return false;
                    }
                    
                    forgotData.code = code;
                    return await verifyForgotPasswordOtp(forgotData.email, code);

                case 3:
                    const password = document.getElementById('resetPassword').value;
                    const confirmPassword = document.getElementById('resetConfirmPassword').value;
                    
                    if (!password || !confirmPassword) {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Missing Password',
                            text: 'Please fill in both password fields',
                            confirmButtonColor: '#1C2B53'
                        });
                        return false;
                    }

                    const val = validatePassword(password);
                    if (!val.valid) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Invalid Password',
                            html: 'Password must meet all requirements:<br>' + val.errors.join('<br>'),
                            confirmButtonColor: '#1C2B53'
                        });
                        return false;
                    }

                    if (password !== confirmPassword) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Passwords Don\'t Match',
                            text: 'Please ensure both passwords are identical',
                            confirmButtonColor: '#1C2B53'
                        });
                        return false;
                    }

                    forgotData.password = password;
                    return true;

                default:
                    return true;
            }
        }

        async function sendForgotPasswordOtp(email) {
            showLoading('Sending verification code...');
            try {
                const response = await fetch('/api/auth/forgot-password/request', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await response.json();
                hideLoading();

                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'OTP Sent',
                        text: 'If the email exists in our system, we have sent a verification code to it.',
                        confirmButtonColor: '#1C2B53'
                    });
                    
                    if (data.code) {
                        console.log('Verification Code (Local Debug Only):', data.code);
                    }
                    return true;
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Failed',
                        text: data.message || 'Failed to send OTP code',
                        confirmButtonColor: '#1C2B53'
                    });
                    return false;
                }
            } catch (err) {
                hideLoading();
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred. Please check your connection and try again.',
                    confirmButtonColor: '#1C2B53'
                });
                return false;
            }
        }

        async function verifyForgotPasswordOtp(email, code) {
            showLoading('Verifying code...');
            try {
                const response = await fetch('/api/auth/forgot-password/verify', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, code })
                });
                const data = await response.json();
                hideLoading();

                if (response.ok && data.success) {
                    return true;
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Invalid Code',
                        text: data.message || 'The verification code is incorrect or expired.',
                        confirmButtonColor: '#1C2B53'
                    });
                    return false;
                }
            } catch (err) {
                hideLoading();
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Connection failed. Please try again.',
                    confirmButtonColor: '#1C2B53'
                });
                return false;
            }
        }

        async function completeReset() {
            showLoading('Resetting password...');
            try {
                const response = await fetch('/api/auth/forgot-password/reset', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email: forgotData.email,
                        code: forgotData.code,
                        password: forgotData.password
                    })
                });
                const data = await response.json();
                hideLoading();

                if (response.ok && data.success) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Success!',
                        text: 'Your password has been reset successfully. You can now log in.',
                        confirmButtonColor: '#1C2B53'
                    });
                    window.location.href = '/';
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Reset Failed',
                        text: data.message || 'Unable to reset password.',
                        confirmButtonColor: '#1C2B53'
                    });
                }
            } catch (err) {
                hideLoading();
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'An error occurred during password reset. Please try again.',
                    confirmButtonColor: '#1C2B53'
                });
            }
        }

        async function resendCode() {
            await sendForgotPasswordOtp(forgotData.email);
        }

        function getVerificationCode() {
            let code = '';
            for (let i = 1; i <= 6; i++) {
                const input = document.getElementById(`code${i}`);
                code += input ? input.value : '';
            }
            return code;
        }

        function showLoading(text = 'Loading...') {
            const overlay = document.getElementById('loadingOverlay');
            if (overlay) {
                overlay.querySelector('.loading-text').textContent = text;
                overlay.classList.add('active');
            }
        }

        function hideLoading() {
            const overlay = document.getElementById('loadingOverlay');
            if (overlay) {
                overlay.classList.remove('active');
            }
        }

        function validatePassword(password) {
            const errors = [];
            let valid = true;
            
            if (password.length < 8) {
                errors.push('• At least 8 characters');
                valid = false;
            }
            if (!/[A-Z]/.test(password)) {
                errors.push('• One uppercase letter');
                valid = false;
            }
            if (!/[0-9]/.test(password)) {
                errors.push('• One number');
                valid = false;
            }
            if (!/[!@@#$%^&*(),.?"':{}|<>_\-+=]/.test(password)) {
                errors.push('• One special character');
                valid = false;
            }
            
            return { valid, errors };
        }

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = event.currentTarget.querySelector('i');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }

        function checkPasswordRequirements(password) {
            const reqs = {
                'req-length': password.length >= 8,
                'req-capital': /[A-Z]/.test(password),
                'req-number': /[0-9]/.test(password),
                'req-special': /[!@@#$%^&*(),.?"':{}|<>_\-+=]/.test(password)
            };
            
            for (const [id, met] of Object.entries(reqs)) {
                const element = document.getElementById(id);
                if (element) {
                    if (met) {
                        element.classList.add('met');
                    } else {
                        element.classList.remove('met');
                    }
                }
            }
        }

        function checkPasswordMatch() {
            const password = document.getElementById('resetPassword').value;
            const confirmPassword = document.getElementById('resetConfirmPassword').value;
            const matchElement = document.getElementById('password-match');
            
            if (!matchElement) return;
            
            if (confirmPassword === '') {
                matchElement.textContent = '';
                matchElement.className = 'password-match';
            } else if (password === confirmPassword) {
                matchElement.textContent = '✓ Passwords match';
                matchElement.className = 'password-match match';
            } else {
                matchElement.textContent = '✗ Passwords do not match';
                matchElement.className = 'password-match no-match';
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            // OTP Code Inputs navigation
            const codeInputs = document.querySelectorAll('.verification-code input');
            
            codeInputs.forEach((input, index) => {
                input.addEventListener('input', function(e) {
                    this.value = this.value.replace(/[^0-9]/g, '');
                    if (this.value.length === 1 && index < codeInputs.length - 1) {
                        codeInputs[index + 1].focus();
                    }
                });
                
                input.addEventListener('keydown', function(e) {
                    if (e.key === 'Backspace' && this.value === '' && index > 0) {
                        codeInputs[index - 1].focus();
                    }
                });
                
                input.addEventListener('paste', function(e) {
                    e.preventDefault();
                    const pastedData = e.clipboardData.getData('text').replace(/[^0-9]/g, '');
                    if (pastedData.length > 0) {
                        for (let i = 0; i < pastedData.length && (index + i) < codeInputs.length; i++) {
                            codeInputs[index + i].value = pastedData[i];
                        }
                        const nextIndex = Math.min(index + pastedData.length, codeInputs.length - 1);
                        codeInputs[nextIndex].focus();
                    }
                });
            });

            // Password requirement event handlers
            const resetPassword = document.getElementById('resetPassword');
            const resetConfirmPassword = document.getElementById('resetConfirmPassword');

            if (resetPassword) {
                resetPassword.addEventListener('input', function() {
                    checkPasswordRequirements(this.value);
                    checkPasswordMatch();
                });
            }

            if (resetConfirmPassword) {
                resetConfirmPassword.addEventListener('input', function() {
                    checkPasswordMatch();
                });
            }
        });
    </script>
</body>
</html>
