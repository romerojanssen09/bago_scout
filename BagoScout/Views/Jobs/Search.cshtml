@{
    @using Microsoft.Extensions.Configuration
    @inject IConfiguration Configuration

    ViewData["Title"] = "Find Jobs";
    ViewData["ActivePage"] = "FindJobs";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link href='https://api.mapbox.com/mapbox-gl-js/v3.0.1/mapbox-gl.css' rel='stylesheet' />
<script src='https://api.mapbox.com/mapbox-gl-js/v3.0.1/mapbox-gl.js'></script>

<style>
    .mapboxgl-ctrl-logo {
        display: none !important;
    }
    .mapboxgl-ctrl-attrib {
        display: none !important;
    }
    body {
        overflow: hidden;
    }
    #map {
        height: 100vh;
        position: fixed;
        top: 0;
        left: 256px;
        right: 0;
        bottom: 0;
    }
    
    @@media (max-width: 768px) {
        #map {
            left: 0;
        }
    }
    
    /* Custom marker styles */
    .custom-marker {
        width: 50px;
        height: 60px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        transition: none !important;
    }
    
    .mapboxgl-marker {
        transition: none !important;
    }
    
    .custom-marker::before {
        content: '';
        position: absolute;
        width: 45px;
        height: 45px;
        background: #1C2B53;
        border-radius: 50% 50% 50% 0;
        transform: rotate(-45deg);
        box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        transition: background 0.3s, transform 0.3s;
        top: 0;
    }
    
    .custom-marker:hover::before {
        background: #6C63FF;
        transform: rotate(-45deg) scale(1.1);
    }
    
    .custom-marker i {
        position: absolute;
        font-size: 20px;
        color: white;
        z-index: 1;
        top: 12px;
    }
    
    /* User location marker */
    .user-location-marker {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #4285F4;
        border: 3px solid white;
        box-shadow: 0 0 0 4px rgba(66, 133, 244, 0.3);
        animation: pulse 2s infinite;
    }
    
    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(66, 133, 244, 0.7);
        }
        70% {
            box-shadow: 0 0 0 10px rgba(66, 133, 244, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(66, 133, 244, 0);
        }
    }
    
    /* Map style selector */
    .map-style-selector {
        position: absolute;
        top: 10px;
        right: 10px;
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        z-index: 1;
        overflow: hidden;
    }
    
    .map-style-selector button {
        padding: 10px 16px;
        border: none;
        background: white;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        color: #374151;
        transition: all 0.3s;
        display: block;
        width: 100%;
        text-align: left;
    }
    
    .map-style-selector button:hover {
        background: #F3F4F6;
    }
    
    .map-style-selector button.active {
        background: #1C2B53;
        color: white;
    }
    
    /* User location badge */
    .user-location-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: #4285F4;
        color: white;
        padding: 10px 16px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        z-index: 1;
        display: none;
    }
    
    .user-location-badge i {
        margin-right: 6px;
    }
    
    /* Cancel route button */
    .cancel-route-btn {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        background: #EF4444;
        color: white;
        padding: 12px 24px;
        border-radius: 25px;
        font-size: 14px;
        font-weight: 600;
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
        z-index: 10;
        display: none;
        border: none;
        cursor: pointer;
        transition: all 0.3s;
    }
    
    .cancel-route-btn:hover {
        background: #DC2626;
        transform: translateX(-50%) scale(1.05);
    }
    
    /* Filter panel */
    .filter-panel {
        position: absolute;
        top: 70px;
        left: 10px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        z-index: 1;
        padding: 16px;
        width: 280px;
        overflow-y: auto;
    }
    
    .filter-panel h3 {
        margin: 0 0 12px 0;
        font-size: 16px;
        font-weight: 600;
        color: #1C2B53;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .filter-close-btn {
        background: none;
        border: none;
        color: #6B7280;
        cursor: pointer;
        font-size: 20px;
        padding: 0;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        transition: all 0.3s;
    }
    
    .filter-close-btn:hover {
        background: #F3F4F6;
        color: #1C2B53;
    }
    
    .filter-group {
        margin-bottom: 16px;
    }
    
    .filter-group label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #374151;
        margin-bottom: 6px;
    }
    
    .filter-group select,
    .filter-group input {
        width: 100%;
        padding: 8px 12px;
        border: 2px solid #E5E7EB;
        border-radius: 8px;
        font-size: 13px;
    }
    
    .filter-group select:focus,
    .filter-group input:focus {
        outline: none;
        border-color: #6C63FF;
    }
    
    .filter-toggle {
        position: absolute;
        top: 70px;
        left: 10px;
        background: white;
        border: none;
        padding: 10px 16px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        color: #1C2B53;
        z-index: 2;
    }
    
    .filter-toggle:hover {
        background: #F3F4F6;
    }
    
    .filter-toggle i {
        margin-right: 6px;
    }
    
    .apply-filters-btn {
        width: 100%;
        background: #1C2B53;
        color: white;
        border: none;
        padding: 10px;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        margin-top: 8px;
    }
    
    .apply-filters-btn:hover {
        background: #6C63FF;
    }
    
    /* Ensure markers are above route */
    .mapboxgl-marker {
        z-index: 10 !important;
        pointer-events: auto !important;
    }
    
    .mapboxgl-popup {
        z-index: 11 !important;
        pointer-events: auto !important;
    }
    
    .mapboxgl-canvas-container {
        position: relative;
    }
    
    /* Hide the accuracy circle from GeolocateControl */
    .mapboxgl-user-location-accuracy-circle {
        display: none !important;
    }
    
    /* Floating Burger Button for Drawer */
    .job-list-toggle {
        position: absolute;
        top: 10px;
        left: 10px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: #1C2B53;
        color: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 6px rgba(0,0,0,0.15);
        z-index: 100;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 18px;
    }
    
    .job-list-toggle:hover {
        background: #6C63FF;
        transform: scale(1.05);
    }
    
    /* Slide-out Drawer Panel */
    .job-list-drawer {
        position: absolute;
        top: 0;
        left: -340px;
        width: 340px;
        bottom: 0;
        background: white;
        z-index: 99;
        transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border-right: 1px solid #E5E7EB;
        box-shadow: 4px 0 15px rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        padding: 20px;
        padding-top: 70px; /* Space for toggling button overlay when open */
    }
    
    .job-list-drawer.open {
        left: 0;
    }
    
    /* Toggle adjustments when drawer is open */
    .job-list-drawer.open ~ .job-list-toggle {
        left: 350px;
    }
    
    .job-list-drawer.open ~ .filter-toggle {
        left: 350px;
    }
    
    .job-list-drawer.open ~ .filter-panel {
        left: 350px;
    }
    
    .job-list-drawer.open ~ .user-location-badge {
        left: 350px;
    }
    
    .drawer-header h3 {
        margin: 0 0 16px 0;
        font-size: 18px;
        font-weight: 700;
        color: #1C2B53;
    }
    
    .drawer-search {
        position: relative;
        margin-bottom: 16px;
    }
    
    .drawer-search i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #8D94A8;
        font-size: 14px;
    }
    
    .drawer-search input {
        width: 100%;
        padding: 10px 12px 10px 36px;
        border: 2px solid #E5E7EB;
        border-radius: 10px;
        font-size: 13px;
        color: #1C2B53;
        transition: border-color 0.3s;
    }
    
    .drawer-search input:focus {
        outline: none;
        border-color: #6C63FF;
    }
    
    /* Quick filters */
    .drawer-filters {
        display: flex;
        gap: 6px;
        overflow-x: auto;
        padding-bottom: 8px;
        margin-bottom: 16px;
        scrollbar-width: none; /* Firefox */
    }
    
    .drawer-filters::-webkit-scrollbar {
        display: none; /* Safari and Chrome */
    }
    
    .filter-pill {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        border: 1px solid #E5E7EB;
        background: white;
        color: #1C2B53;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.2s;
    }
    
    .filter-pill:hover {
        background: #F3F4F6;
    }
    
    .filter-pill.active {
        background: #1C2B53;
        color: white;
        border-color: #1C2B53;
    }
    
    /* Scrollable Jobs list */
    .drawer-jobs-list {
        flex: 1;
        overflow-y: auto;
        padding-right: 4px;
    }
    
    .drawer-jobs-list::-webkit-scrollbar {
        width: 6px;
    }
    
    .drawer-jobs-list::-webkit-scrollbar-track {
        background: #F3F4F6;
    }
    
    .drawer-jobs-list::-webkit-scrollbar-thumb {
        background: #D1D5DB;
        border-radius: 3px;
    }
    
    /* Job Card inside drawer */
    .drawer-job-card {
        background: white;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        padding: 14px;
        margin-bottom: 12px;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        display: flex;
        flex-direction: column;
        gap: 8px;
        text-align: left;
    }
    
    .drawer-job-card:hover {
        border-color: #6C63FF;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(108, 99, 255, 0.1);
    }
    
    .drawer-job-card .card-title {
        font-size: 14px;
        font-weight: 700;
        color: #1C2B53;
        margin: 0;
        line-height: 1.3;
    }
    
    .drawer-job-card .card-company {
        font-size: 12px;
        font-weight: 600;
        color: #6C63FF;
        margin: 0;
    }
    
    .drawer-job-card .card-location {
        font-size: 11px;
        color: #8D94A8;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    
    .drawer-job-card .card-badges {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 4px;
    }
    
    .drawer-job-card .badge-type {
        background: #E0E7FF;
        color: #3730A3;
        font-size: 9px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 6px;
    }
    
    .drawer-job-card .badge-salary {
        background: #D1FAE5;
        color: #065F46;
        font-size: 9px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 6px;
    }
    
    /* Empty State */
    .drawer-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        color: #8D94A8;
        text-align: center;
        gap: 8px;
    }
    
    .drawer-empty-state i {
        font-size: 32px;
    }
    
    .drawer-empty-state p {
        font-size: 13px;
        font-weight: 600;
        margin: 0;
    }
</style>

<div id="map">
        <!-- Slide-out Drawer Panel -->
        <div class="job-list-drawer" id="jobListDrawer">
            <div class="drawer-header">
                <h3>Job Opportunities</h3>
            </div>
            
            <div class="drawer-search">
                <i class="fas fa-search"></i>
                <input type="text" id="drawerSearchInput" placeholder="Search jobs..." oninput="onDrawerSearch(this.value)">
            </div>
            
            <div class="drawer-filters">
                <button onclick="filterByJobType('')" class="filter-pill active" id="pill-all">All</button>
                <button onclick="filterByJobType('Full-time')" class="filter-pill" id="pill-full">Full-Time</button>
                <button onclick="filterByJobType('Part-time')" class="filter-pill" id="pill-part">Part-Time</button>
                <button onclick="filterByJobType('Contract')" class="filter-pill" id="pill-contract">Contract</button>
                <button onclick="filterByJobType('Internship')" class="filter-pill" id="pill-intern">Internship</button>
            </div>
            
            <div class="drawer-jobs-list" id="drawerJobsList">
                <!-- Rendered dynamically -->
            </div>
        </div>

        <!-- Floating Burger Menu Button -->
        <button class="job-list-toggle" id="jobListToggle" onclick="toggleJobList()">
            <i class="fas fa-bars"></i>
        </button>

        <div class="user-location-badge" id="userLocationBadge">
            <i class="fas fa-location-arrow"></i>
            <span>Your Location</span>
        </div>
        
        <button class="filter-toggle" id="filterToggle" onclick="toggleFilters()">
            <i class="fas fa-filter"></i>
            Filters
        </button>
        
        <div class="filter-panel" id="filterPanel" style="display: none;">
            <h3>
                <span><i class="fas fa-sliders-h"></i> Filter Jobs</span>
                <button class="filter-close-btn" onclick="toggleFilters()">
                    <i class="fas fa-times"></i>
                </button>
            </h3>
            
            <div class="filter-group">
                <label>Distance from me</label>
                <select id="distanceFilter">
                    <option value="all">All distances</option>
                    <option value="5">Within 5 km</option>
                    <option value="10">Within 10 km</option>
                    <option value="25">Within 25 km</option>
                    <option value="50">Within 50 km</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Job Type</label>
                <select id="jobTypeFilter">
                    <option value="all">All types</option>
                    <option value="Full-time">Full-time</option>
                    <option value="Part-time">Part-time</option>
                    <option value="Contract">Contract</option>
                    <option value="Freelance">Freelance</option>
                    <option value="Internship">Internship</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Experience Level</label>
                <select id="experienceFilter">
                    <option value="all">All levels</option>
                    <option value="Entry Level">Entry Level</option>
                    <option value="Mid Level">Mid Level</option>
                    <option value="Senior Level">Senior Level</option>
                    <option value="Executive">Executive</option>
                </select>
            </div>
            
            <div class="filter-group">
                <label>Search by title or company</label>
                <input type="text" id="searchFilter" placeholder="e.g. Developer, Google">
            </div>
            
            <button class="apply-filters-btn" onclick="applyFilters()">
                <i class="fas fa-check"></i> Apply Filters
            </button>
        </div>
        
        <button class="cancel-route-btn" id="cancelRouteBtn" onclick="cancelRoute()">
            <i class="fas fa-times"></i> Cancel Route
        </button>
        
        <div class="map-style-selector">
            <button onclick="changeMapStyle('streets-v12')" class="active" data-style="streets-v12">
                <i class="fas fa-map"></i> Street Map
            </button>
            <button onclick="changeMapStyle('satellite-streets-v12')" data-style="satellite-streets-v12">
                <i class="fas fa-satellite"></i> Satellite
            </button>
            <button onclick="changeMapStyle('outdoors-v12')" data-style="outdoors-v12">
                <i class="fas fa-mountain"></i> Outdoors
            </button>
            <button onclick="changeMapStyle('dark-v11')" data-style="dark-v11">
                <i class="fas fa-moon"></i> Dark
            </button>
        </div>
    </div>

<script>
    mapboxgl.accessToken = '@Configuration["MapBox:Token"]';
    
    const map = new mapboxgl.Map({
        container: 'map',
        style: 'mapbox://styles/mapbox/streets-v12',
        center: [122.8425853, 10.5288236],
        zoom: 13
    });

    map.addControl(new mapboxgl.NavigationControl());
    
    let userLocation = null;
    let userMarker = null;
    let allJobs = [];
    let filteredJobs = [];
    let jobMarkers = [];
    let currentRoute = null;

    const geolocate = new mapboxgl.GeolocateControl({
        positionOptions: {
            enableHighAccuracy: true
        },
        trackUserLocation: true,
        showUserHeading: true
    });
    
    map.addControl(geolocate);

    geolocate.on('geolocate', (e) => {
        userLocation = [e.coords.longitude, e.coords.latitude];
        document.getElementById('userLocationBadge').style.display = 'block';
        
        if (userMarker) {
            userMarker.remove();
        }
        
        const el = document.createElement('div');
        el.className = 'user-location-marker';
        
        userMarker = new mapboxgl.Marker({
            element: el,
            anchor: 'center'
        })
            .setLngLat(userLocation)
            .addTo(map);
    });

    function changeMapStyle(style) {
        map.setStyle('mapbox://styles/mapbox/' + style);
        
        document.querySelectorAll('.map-style-selector button').forEach(btn => {
            btn.classList.remove('active');
            if (btn.getAttribute('data-style') === style) {
                btn.classList.add('active');
            }
        });
        
        map.once('styledata', () => {
            if (allJobs.length > 0) {
                addJobMarkers();
                renderJobList(filteredJobs.length > 0 ? filteredJobs : allJobs);
            }
        });
    }

    function calculateDistance(lat1, lon1, lat2, lon2) {
        const R = 6371;
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLon = (lon2 - lon1) * Math.PI / 180;
        const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                  Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                  Math.sin(dLon/2) * Math.sin(dLon/2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
        return R * c;
    }

    async function drawRoute(jobLng, jobLat) {
        if (!userLocation) return;

        if (currentRoute && map.getLayer('route')) {
            map.removeLayer('route');
            map.removeSource('route');
            currentRoute = null;
        }

        try {
            const query = await fetch(
                `https://api.mapbox.com/directions/v5/mapbox/driving/${userLocation[0]},${userLocation[1]};${jobLng},${jobLat}?geometries=geojson&access_token=${mapboxgl.accessToken}`
            );
            const json = await query.json();
            const data = json.routes[0];
            const route = data.geometry.coordinates;

            currentRoute = {
                type: 'Feature',
                properties: {},
                geometry: {
                    type: 'LineString',
                    coordinates: route
                }
            };

            map.addSource('route', {
                type: 'geojson',
                data: currentRoute
            });

            // Add route layer above roads but below labels
            const layers = map.getStyle().layers;
            let labelLayerId;
            for (const layer of layers) {
                if (layer.type === 'symbol' && layer.layout['text-field']) {
                    labelLayerId = layer.id;
                    break;
                }
            }

            map.addLayer({
                id: 'route',
                type: 'line',
                source: 'route',
                layout: {
                    'line-join': 'round',
                    'line-cap': 'round'
                },
                paint: {
                    'line-color': '#4285F4',
                    'line-width': 6,
                    'line-opacity': 0.85
                }
            }, labelLayerId);

            // Recreate markers to ensure they're on top
            const tempJobs = filteredJobs.length > 0 ? [...filteredJobs] : [...allJobs];
            jobMarkers.forEach(marker => marker.remove());
            jobMarkers = [];
            
            tempJobs.forEach(job => {
                createJobMarker(job);
            });

            // Fit map to show route
            const coordinates = route;
            const bounds = coordinates.reduce((bounds, coord) => {
                return bounds.extend(coord);
            }, new mapboxgl.LngLatBounds(coordinates[0], coordinates[0]));

            map.fitBounds(bounds, {
                padding: 80
            });
            
            // Show cancel route button
            document.getElementById('cancelRouteBtn').style.display = 'block';
        } catch (error) {
            console.error('Error drawing route:', error);
        }
    }

    function cancelRoute() {
        if (currentRoute && map.getLayer('route')) {
            map.removeLayer('route');
            map.removeSource('route');
            currentRoute = null;
        }
        document.getElementById('cancelRouteBtn').style.display = 'none';
    }

    function toggleFilters() {
        const panel = document.getElementById('filterPanel');
        const toggle = document.getElementById('filterToggle');
        if (panel.style.display === 'none') {
            panel.style.display = 'block';
            toggle.style.display = 'none';
        } else {
            panel.style.display = 'none';
            toggle.style.display = 'block';
        }
    }

    function applyFilters() {
        const distanceFilter = document.getElementById('distanceFilter').value;
        const jobTypeFilter = document.getElementById('jobTypeFilter').value;
        const experienceFilter = document.getElementById('experienceFilter').value;
        const searchFilter = document.getElementById('searchFilter').value.toLowerCase();

        filteredJobs = allJobs.filter(job => {
            // Distance filter
            if (distanceFilter !== 'all' && userLocation) {
                const dist = calculateDistance(
                    userLocation[1], userLocation[0],
                    job.latitude, job.longitude
                );
                if (dist > parseFloat(distanceFilter)) return false;
            }

            // Job type filter
            if (jobTypeFilter !== 'all' && job.jobType !== jobTypeFilter) {
                return false;
            }

            // Experience filter
            if (experienceFilter !== 'all' && job.experienceLevel !== experienceFilter) {
                return false;
            }

            // Search filter
            if (searchFilter && !job.title.toLowerCase().includes(searchFilter) && 
                !job.company.toLowerCase().includes(searchFilter)) {
                return false;
            }

            return true;
        });

        // Update markers
        jobMarkers.forEach(marker => marker.remove());
        jobMarkers = [];
        
        const jobsToDisplay = (filteredJobs.length > 0 || 
                              distanceFilter !== 'all' || 
                              jobTypeFilter !== 'all' || 
                              experienceFilter !== 'all' || 
                              searchFilter) ? filteredJobs : allJobs;
        
        jobsToDisplay.forEach(job => {
            createJobMarker(job);
        });

        renderJobList(jobsToDisplay);

        // Show result count
        Swal.fire({
            icon: 'success',
            title: 'Filters Applied',
            text: `Showing ${jobsToDisplay.length} job(s)`,
            timer: 2000,
            showConfirmButton: false
        });

        toggleFilters();
    }

    function createJobMarker(job) {
        // Create popup with job title
        const popup = new mapboxgl.Popup({
            offset: 25,
            closeButton: false,
            closeOnClick: false
        }).setHTML(`
            <div style="padding: 8px; cursor: pointer;" class="job-popup-content">
                <h4 style="margin: 0; font-size: 14px; font-weight: 600; color: #1C2B53;">${job.title}</h4>
                <p style="margin: 4px 0 0 0; font-size: 12px; color: #6B7280;">${job.company}</p>
            </div>
        `);

        // Use default Mapbox marker with custom color
        const marker = new mapboxgl.Marker({
            color: '#1C2B53',
            scale: 1.2
        })
            .setLngLat([job.longitude, job.latitude])
            .setPopup(popup)
            .addTo(map);

        let popupTimeout;

        // Add click event to open modal
        marker.getElement().addEventListener('click', () => {
            showJobModal(job);
        });

        // Show popup on hover
        marker.getElement().addEventListener('mouseenter', () => {
            clearTimeout(popupTimeout);
            popup.addTo(map);
        });

        marker.getElement().addEventListener('mouseleave', () => {
            popupTimeout = setTimeout(() => {
                const popupElement = popup.getElement();
                if (popupElement && !popupElement.matches(':hover')) {
                    popup.remove();
                }
            }, 100);
        });

        // Keep popup open when hovering over it
        popup.on('open', () => {
            const popupElement = popup.getElement();
            if (popupElement) {
                popupElement.addEventListener('mouseenter', () => {
                    clearTimeout(popupTimeout);
                });
                
                popupElement.addEventListener('mouseleave', () => {
                    popup.remove();
                });
            }
        });

        jobMarkers.push(marker);
    }

    function addJobMarkers() {
        jobMarkers.forEach(marker => marker.remove());
        jobMarkers = [];

        allJobs.forEach(job => {
            createJobMarker(job);
        });
    }

    async function loadJobs() {
        try {
            const response = await fetch('/api/jobs/all');
            
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            
            const jobs = await response.json();

            if (!Array.isArray(jobs) || jobs.length === 0) {
                Swal.fire({
                    icon: 'info',
                    title: 'No Jobs Available',
                    text: 'There are currently no job postings. Check back later!',
                    confirmButtonColor: '#1C2B53'
                });
                return;
            }

            allJobs = jobs;
            addJobMarkers();
            renderJobList(allJobs);
        } catch (error) {
            console.error('Error loading jobs:', error);
            Swal.fire({
                icon: 'info',
                title: 'No Jobs Available',
                text: 'There are currently no job postings. Please check back later!',
                confirmButtonColor: '#1C2B53'
            });
        }
    }

    function showJobModal(job) {
        let distance = '';
        if (userLocation) {
            const dist = calculateDistance(
                userLocation[1], userLocation[0],
                job.latitude, job.longitude
            );
            distance = `<p style="margin-bottom: 8px; color: #4285F4; font-weight: 600;"><i class="fas fa-route"></i> ${dist.toFixed(1)} km from your location</p>`;
        }

        Swal.fire({
            title: job.title,
            html: `
                <div style="text-align: left;">
                    <p style="color: #6C63FF; font-weight: 600; margin-bottom: 12px; font-size: 16px;">
                        <i class="fas fa-building"></i> ${job.company}
                    </p>
                    <p style="margin-bottom: 8px; color: #6B7280;">
                        <i class="fas fa-map-marker-alt"></i> ${job.address}
                    </p>
                    ${distance}
                    ${job.salaryRange ? `<p style="margin-bottom: 8px; color: #6B7280;"><i class="fas fa-money-bill-wave"></i> ${job.salaryRange}</p>` : ''}
                    ${job.jobType ? `<p style="margin-bottom: 8px; color: #6B7280;"><i class="fas fa-briefcase"></i> ${job.jobType}</p>` : ''}
                    ${job.experienceLevel ? `<p style="margin-bottom: 8px; color: #6B7280;"><i class="fas fa-chart-line"></i> ${job.experienceLevel}</p>` : ''}
                    <hr style="margin: 16px 0; border: none; border-top: 1px solid #E5E7EB;">
                    <h4 style="color: #1C2B53; font-weight: 600; margin-bottom: 8px; font-size: 15px;">Description</h4>
                    <p style="color: #374151; margin-bottom: 16px; line-height: 1.6;">${job.description}</p>
                    ${job.requirements ? `
                        <h4 style="color: #1C2B53; font-weight: 600; margin-bottom: 8px; font-size: 15px;">Requirements</h4>
                        <p style="color: #374151; line-height: 1.6;">${job.requirements}</p>
                    ` : ''}
                </div>
            `,
            width: 600,
            showDenyButton: userLocation ? true : false,
            denyButtonText: userLocation ? '<i class="fas fa-route"></i> Show Route' : '',
            confirmButtonText: '<i class="fas fa-paper-plane"></i> Apply Now',
            showCancelButton: true,
            cancelButtonText: 'Close',
            confirmButtonColor: '#1C2B53',
            denyButtonColor: '#4285F4',
            cancelButtonColor: '#6B7280'
        }).then((result) => {
            if (result.isConfirmed) {
                // Check profile completion before applying
                checkProfileAndApply(job.jobId);
            } else if (result.isDenied && userLocation) {
                drawRoute(job.longitude, job.latitude);
            }
        });
    }

    async function checkProfileAndApply(jobId) {
        try {
            const checkResponse = await fetch('/api/profile/check-completion');
            const checkData = await checkResponse.json();
            
            if (!checkData.isComplete) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Complete Your Profile First',
                    html: 'You need to complete your profile before applying to jobs.<br><br>Please fill in:<br>• Full Name<br>• Phone Number<br>• At least one skill',
                    confirmButtonText: 'Go to Profile',
                    confirmButtonColor: '#1C2B53',
                    showCancelButton: true,
                    cancelButtonText: 'Cancel'
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = '/Profile/Index';
                    }
                });
                return;
            }
            
            // Profile is complete, proceed with application
            submitApplication(jobId);
        } catch (error) {
            console.error('Error checking profile:', error);
            // If check fails, still allow application
            submitApplication(jobId);
        }
    }

    async function submitApplication(jobId) {
        try {
            Swal.fire({
                title: 'Submitting Application...',
                text: 'Please wait',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            const response = await fetch('/api/jobs/apply', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    jobId: jobId,
                    coverLetter: ''
                })
            });

            const result = await response.json();

            if (response.ok) {
                await Swal.fire({
                    icon: 'success',
                    title: 'Application Submitted!',
                    text: 'Your application has been sent to the employer. Good luck!',
                    confirmButtonColor: '#1C2B53'
                });
            } else {
                Swal.fire({
                    icon: 'error',
                    title: 'Application Failed',
                    text: result.message || 'Failed to submit application',
                    confirmButtonColor: '#1C2B53'
                });
            }
        } catch (error) {
            console.error('Error submitting application:', error);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'An error occurred while submitting your application',
                confirmButtonColor: '#1C2B53'
            });
        }
    }

    map.on('load', () => {
        loadJobs();
        checkProfileCompletion();
        
        setTimeout(() => {
            geolocate.trigger();
        }, 1000);
    });

    async function checkProfileCompletion() {
        try {
            const response = await fetch('/api/profile/check-completion');
            const data = await response.json();
            
            if (!data.isComplete) {
                setTimeout(() => {
                    Swal.fire({
                        icon: 'info',
                        title: 'Complete Your Profile',
                        html: 'Complete your profile to start applying for jobs!<br><br>Add:<br>• Full Name<br>• Phone Number<br>• Skills',
                        confirmButtonText: 'Complete Profile',
                        confirmButtonColor: '#1C2B53',
                        showCancelButton: true,
                        cancelButtonText: 'Later'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '/Profile/Index';
                        }
                    });
                }, 2000);
            }
        } catch (error) {
            console.error('Error checking profile:', error);
        }
    }

    /* Jobs List Drawer Controls */
    function toggleJobList() {
        const drawer = document.getElementById('jobListDrawer');
        const toggle = document.getElementById('jobListToggle');
        const icon = toggle.querySelector('i');
        
        drawer.classList.toggle('open');
        if (drawer.classList.contains('open')) {
            icon.className = 'fas fa-times';
        } else {
            icon.className = 'fas fa-bars';
        }
    }

    function renderJobList(jobsToRender) {
        const listContainer = document.getElementById('drawerJobsList');
        if (!listContainer) return;
        
        listContainer.innerHTML = '';
        
        const displayJobs = jobsToRender || (filteredJobs.length > 0 ? filteredJobs : allJobs);
        
        if (displayJobs.length === 0) {
            listContainer.innerHTML = `
                <div class="drawer-empty-state">
                    <i class="fas fa-search"></i>
                    <p>No jobs found</p>
                </div>
            `;
            return;
        }
        
        displayJobs.forEach(job => {
            const card = document.createElement('div');
            card.className = 'drawer-job-card';
            card.onclick = () => {
                map.flyTo({
                    center: [job.longitude, job.latitude],
                    zoom: 15
                });
                showJobModal(job);
            };
            
            let distanceHtml = '';
            if (userLocation && job.latitude && job.longitude) {
                const dist = calculateDistance(
                    userLocation[1], userLocation[0],
                    job.latitude, job.longitude
                );
                distanceHtml = `<span class="badge-distance" style="background:#E0F2FE;color:#0369A1;font-size:9px;font-weight:700;padding:2px 6px;border-radius:6px;display:inline-flex;align-items:center;gap:3px;"><i class="fas fa-route"></i> ${dist.toFixed(1)} km</span>`;
            }
            
            card.innerHTML = `
                <div class="flex justify-between items-start">
                    <div>
                        <h4 class="card-title">${escapeHtml(job.title)}</h4>
                        <p class="card-company">${escapeHtml(job.company)}</p>
                    </div>
                    <i class="fas fa-chevron-right text-medium-gray text-xs self-center"></i>
                </div>
                <p class="card-location">
                    <i class="fas fa-map-marker-alt"></i> ${escapeHtml(job.address)}
                </p>
                <div class="card-badges">
                    ${job.jobType ? `<span class="badge-type">${escapeHtml(job.jobType)}</span>` : ''}
                    ${job.salaryRange ? `<span class="badge-salary">${escapeHtml(job.salaryRange)}</span>` : ''}
                    ${distanceHtml}
                </div>
            `;
            listContainer.appendChild(card);
        });
    }

    function onDrawerSearch(value) {
        document.getElementById('searchFilter').value = value;
        filterJobsSilent();
    }

    function filterByJobType(type) {
        const select = document.getElementById('jobTypeFilter');
        if (type === '') {
            select.value = 'all';
        } else {
            select.value = type;
        }
        
        document.querySelectorAll('.filter-pill').forEach(pill => {
            pill.classList.remove('active');
        });
        
        if (type === '') document.getElementById('pill-all').classList.add('active');
        else if (type === 'Full-time') document.getElementById('pill-full').classList.add('active');
        else if (type === 'Part-time') document.getElementById('pill-part').classList.add('active');
        else if (type === 'Contract') document.getElementById('pill-contract').classList.add('active');
        else if (type === 'Internship') document.getElementById('pill-intern').classList.add('active');
        
        filterJobsSilent();
    }

    function filterJobsSilent() {
        const distanceFilter = document.getElementById('distanceFilter').value;
        const jobTypeFilter = document.getElementById('jobTypeFilter').value;
        const experienceFilter = document.getElementById('experienceFilter').value;
        const searchFilter = document.getElementById('searchFilter').value.toLowerCase();

        filteredJobs = allJobs.filter(job => {
            if (distanceFilter !== 'all' && userLocation) {
                const dist = calculateDistance(
                    userLocation[1], userLocation[0],
                    job.latitude, job.longitude
                );
                if (dist > parseFloat(distanceFilter)) return false;
            }
            if (jobTypeFilter !== 'all' && job.jobType !== jobTypeFilter) {
                return false;
            }
            if (experienceFilter !== 'all' && job.experienceLevel !== experienceFilter) {
                return false;
            }
            if (searchFilter && !job.title.toLowerCase().includes(searchFilter) && 
                !job.company.toLowerCase().includes(searchFilter)) {
                return false;
            }
            return true;
        });

        jobMarkers.forEach(marker => marker.remove());
        jobMarkers = [];
        
        const jobsToDisplay = (filteredJobs.length > 0 || 
                              distanceFilter !== 'all' || 
                              jobTypeFilter !== 'all' || 
                              experienceFilter !== 'all' || 
                              searchFilter) ? filteredJobs : allJobs;
                              
        jobsToDisplay.forEach(job => {
            createJobMarker(job);
        });

        renderJobList(jobsToDisplay);
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }
</script>
