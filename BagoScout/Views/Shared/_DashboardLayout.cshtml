@{
    var userType = Context.Session.GetString("UserType");
    var isSeeker = userType == "seeker";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BagoScout</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'primary-purple': '#6C63FF',
                        'dark-navy': '#1C2B53',
                        'medium-gray': '#8D94A8',
                        'light-bg': '#F0F4FF',
                    }
                }
            }
        }
    </script>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background: #F9FAFB;
            overflow: hidden;
        }
        .sidebar {
            background: #1C2B53;
            height: 100vh;
            color: white;
            position: fixed;
            left: 0;
            top: 0;
            width: 256px;
            overflow-y: auto;
            z-index: 40;
            transition: transform 0.3s ease-in-out;
        }
        .sidebar::-webkit-scrollbar {
            width: 6px;
        }
        .sidebar::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.1);
        }
        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.3);
            border-radius: 3px;
        }
        .main-content {
            margin-left: 256px;
            height: 100vh;
            overflow-y: auto;
            overflow-x: hidden;
            background: #F9FAFB;
            width: calc(100% - 256px);
        }
        .nav-item {
            padding: 14px 20px;
            margin: 8px 16px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: white;
        }
        .nav-item:hover {
            background: rgba(255,255,255,0.1);
        }
        .nav-item.active {
            background: #6C63FF;
        }
        .mobile-menu-btn {
            display: none;
        }
        .mobile-overlay {
            display: none;
        }
        
        /* Mobile Responsive */
        @@media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.mobile-open {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
                width: 100%;
            }
            .mobile-menu-btn {
                display: block;
                position: fixed;
                top: 16px;
                left: 16px;
                z-index: 50;
                background: #1C2B53;
                color: white;
                padding: 12px;
                border-radius: 8px;
                cursor: pointer;
                box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            }
            .mobile-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.5);
                z-index: 30;
            }
            .mobile-overlay.active {
                display: block;
            }
        }
    </style>
</head>
<body>
    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
        <i class="fas fa-bars text-xl"></i>
    </button>

    <!-- Mobile Overlay -->
    <div class="mobile-overlay" id="mobileOverlay" onclick="toggleMobileMenu()"></div>

    <div class="flex">
        <!-- Sidebar -->
        <div class="sidebar" id="sidebar">
            <div class="p-6">
                <div class="flex items-center justify-center gap-3 mb-8">
                    <img src="/imgs/logo.png" alt="BagoScout" class="h-10 w-auto">
                </div>
                <nav>
                    @if (isSeeker)
                    {
                        <a href="/Dashboard/Seeker" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-home"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/Jobs/Search" class="nav-item @(ViewData["ActivePage"]?.ToString() == "FindJobs" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-search"></i>
                            <span>Find Jobs</span>
                        </a>
                        <a href="/Applications/Index" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Applications" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-file-alt"></i>
                            <span>Applications</span>
                        </a>
                        <a href="/Messages/Index" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Messages" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-comments"></i>
                            <span>Messages</span>
                        </a>
                        <a href="/Profile/Index" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Profile" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-user"></i>
                            <span>Profile</span>
                        </a>
                    }
                    else
                    {
                        <a href="/Dashboard/Employer" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-home"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/Jobs/Manage" class="nav-item @(ViewData["ActivePage"]?.ToString() == "JobPostings" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-briefcase"></i>
                            <span>Job Postings</span>
                        </a>
                        <a href="/Candidates/Index" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Candidates" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-users"></i>
                            <span>Candidates</span>
                        </a>
                        <a href="/Messages/Index" class="nav-item @(ViewData["ActivePage"]?.ToString() == "Messages" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-comments"></i>
                            <span>Messages</span>
                        </a>
                        <a href="/Company/Profile" class="nav-item @(ViewData["ActivePage"]?.ToString() == "CompanyProfile" ? "active" : "")" onclick="closeMobileMenu()">
                            <i class="fas fa-building"></i>
                            <span>Company Profile</span>
                        </a>
                    }
                    <div class="nav-item" onclick="logout()">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </div>
                </nav>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content p-4 md:p-8">
            @RenderBody()
        </div>
    </div>

    <script>
        function toggleMobileMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobileOverlay');
            sidebar.classList.toggle('mobile-open');
            overlay.classList.toggle('active');
        }

        function closeMobileMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobileOverlay');
            sidebar.classList.remove('mobile-open');
            overlay.classList.remove('active');
        }

        async function logout() {
            const result = await Swal.fire({
                title: 'Logout',
                text: 'Are you sure you want to logout?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#1C2B53',
                cancelButtonColor: '#6B7280',
                confirmButtonText: 'Yes, logout',
                cancelButtonText: 'Cancel'
            });

            if (result.isConfirmed) {
                try {
                    await fetch('/api/auth/logout', { method: 'POST' });
                    window.location.href = '/';
                } catch (error) {
                    console.error('Logout error:', error);
                    window.location.href = '/';
                }
            }
        }
    </script>
</body>
</html>
