@{
    ViewData["Title"] = "Candidates";
    ViewData["ActivePage"] = "Candidates";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    /* Desktop & Base Styles */
    .applicant-card {
        background: white;
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 16px;
        transition: all 0.3s;
        position: relative;
    }
    .applicant-card:hover {
        border-color: #6C63FF;
        box-shadow: 0 4px 12px rgba(108, 99, 255, 0.1);
    }
    .card-header {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 16px;
    }
    .card-content {
        flex: 1;
        min-width: 0;
    }
    .status-badge {
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 600;
        white-space: nowrap;
        display: inline-block;
        position: absolute;
        top: 24px;
        right: 24px;
    }
    .card-info {
        margin-top: 12px;
    }
    .card-info .info-row {
        display: flex;
        gap: 24px;
        margin-bottom: 16px;
        font-size: 14px;
        color: #6B7280;
    }
    .card-info .info-row > div {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .action-buttons {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
    }
    .action-buttons .left-buttons {
        display: flex;
        gap: 8px;
    }
    .action-buttons .right-buttons {
        display: flex;
        gap: 8px;
    }
    .status-pending { background: #FEF3C7; color: #92400E; }
    .status-reviewed { background: #DBEAFE; color: #1E40AF; }
    .status-accepted { background: #D1FAE5; color: #065F46; }
    .status-rejected { background: #FEE2E2; color: #991B1B; }

    /* Custom Scrollbar for SweetAlert Profile */
    .swal-html-container {
        max-height: 70vh;
        overflow-y: auto !important;
        padding: 0 1rem !important;
    }

    /* Mobile Responsive Logic */
    @@media (max-width: 768px) {
        .applicant-card {
            padding: 16px;
        }
        .status-badge {
            position: absolute !important;
            top: 16px !important;
            right: 16px !important;
            left: auto !important;
            z-index: 10;
            font-size: 12px !important;
            padding: 4px 12px !important;
        }
        .card-header {
            margin-bottom: 12px;
            margin-top: 0;
        }
        .card-header img,
        .card-header > div {
            width: 48px !important;
            height: 48px !important;
            font-size: 18px !important;
        }
        .card-content h3 {
            font-size: 16px !important;
        }
        .card-content p {
            font-size: 13px !important;
        }
        .card-info .info-row {
            flex-direction: column !important;
            gap: 8px !important;
            font-size: 12px !important;
        }
        .action-buttons {
            flex-direction: column !important;
        }
        .action-buttons .left-buttons {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
            width: 100%;
            gap: 8px;
        }
        .action-buttons .left-buttons .btn-message {
            grid-column: 1 / -1;
            margin-bottom: 8px;
        }
        .action-buttons .right-buttons {
            display: grid !important;
            grid-template-columns: 1fr 1fr !important;
            width: 100%;
            gap: 8px;
        }
        .action-buttons button {
            font-size: 13px !important;
            padding: 10px 12px !important;
        }
    }
</style>

<div class="page-header mb-6 px-4 md:px-0">
    <h2 class="text-2xl md:text-3xl font-bold text-gray-800 flex items-center gap-3">
        <i class="fas fa-users text-primary-purple"></i>
        Candidates
    </h2>
    <p class="text-gray-600 mt-2">Review and manage job applications</p>
</div>

<div class="bg-white rounded-2xl p-4 md:p-6 shadow-sm">
    <div id="applicationsContainer">
        <div class="text-center py-12">
            <i class="fas fa-spinner fa-spin text-4xl text-gray-400 mb-4"></i>
            <p class="text-gray-600">Loading applications...</p>
        </div>
    </div>
</div>

<script>
    // --- Data Loading ---
    async function loadApplications() {
        try {
            const response = await fetch('/api/applications/employer');
            if (!response.ok) throw new Error('Failed to fetch');
            
            const applications = await response.json();
            const container = document.getElementById('applicationsContainer');
            
            if (!Array.isArray(applications) || applications.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-12">
                        <i class="fas fa-users text-6xl text-gray-300 mb-4"></i>
                        <h3 class="text-xl font-bold text-gray-700 mb-2">No Applications Yet</h3>
                        <a href="/Jobs/Manage" class="inline-block bg-indigo-900 text-white px-6 py-3 rounded-lg font-semibold hover:bg-opacity-90 transition">
                            <i class="fas fa-plus mr-2"></i> Post a Job
                        </a>
                    </div>`;
                return;
            }

            container.innerHTML = applications.map(app => {
                const appliedDate = new Date(app.appliedAt).toLocaleDateString('en-US', {
                    year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
                });

                const statusClass = `status-${app.status.toLowerCase()}`;
                const capitalizedName = app.seekerName.split(' ').map(word => 
                    word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()
                ).join(' ');

                return `
                    <div class="applicant-card" data-seeker-id="${app.seekerId}" data-application-id="${app.applicationId}">
                        <span class="status-badge ${statusClass}">${app.status}</span>
                        
                        <div class="card-header">
                            ${app.seekerPhoto ? `
                                <img src="${app.seekerPhoto}" alt="${capitalizedName}" class="w-16 h-16 rounded-full object-cover flex-shrink-0">
                            ` : `
                                <div class="w-16 h-16 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-user text-indigo-600 text-2xl"></i>
                                </div>
                            `}
                            <div class="card-content">
                                <h3 class="text-lg font-bold text-gray-800 mb-1">${capitalizedName}</h3>
                                <p class="text-sm text-gray-600">Applied for: <span class="font-semibold text-primary-purple">${app.jobTitle}</span></p>
                            </div>
                        </div>

                        <div class="card-info">
                            <div class="info-row">
                                <div>
                                    <i class="fas fa-envelope text-indigo-400"></i>
                                    <span>${app.seekerEmail}</span>
                                </div>
                                <div>
                                    <i class="fas fa-phone text-indigo-400"></i>
                                    <span>${app.seekerPhone || 'N/A'}</span>
                                </div>
                                <div>
                                    <i class="fas fa-calendar text-indigo-400"></i>
                                    <span>${appliedDate}</span>
                                </div>
                            </div>

                            <div class="action-buttons">
                                <div class="left-buttons">
                                    <button onclick="viewApplicant(${app.applicationId})" class="btn-profile px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-semibold hover:bg-blue-700 transition">
                                        <i class="fas fa-eye mr-1"></i> View Profile
                                    </button>
                                    <button id="contact-btn-${app.applicationId}" onclick="handleEmailButton('${app.seekerEmail}', '${capitalizedName}', ${app.applicationId}, ${app.seekerId})" class="btn-email px-4 py-2 bg-gray-600 text-white rounded-lg text-sm font-semibold hover:bg-gray-700 transition">
                                        <i class="fas fa-envelope mr-1"></i> <span id="contact-text-${app.applicationId}">Email</span>
                                    </button>
                                    <button onclick="openMessaging(${app.seekerId}, '${capitalizedName}', ${app.applicationId})" class="btn-message px-4 py-2 bg-purple-600 text-white rounded-lg text-sm font-semibold hover:bg-purple-700 transition">
                                        <i class="fas fa-comments mr-1"></i> Message
                                    </button>
                                </div>
                                ${app.status === 'Pending' || app.status === 'Reviewed' ? `
                                    <div class="right-buttons">
                                        <button onclick="updateApplicationStatus(${app.applicationId}, 'Accepted')" class="btn-accept px-4 py-2 bg-emerald-600 text-white rounded-lg text-sm font-semibold hover:bg-emerald-700 transition">
                                            <i class="fas fa-check mr-1"></i> Accept
                                        </button>
                                        <button onclick="updateApplicationStatus(${app.applicationId}, 'Rejected')" class="btn-reject px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-semibold hover:bg-red-700 transition">
                                            <i class="fas fa-times mr-1"></i> Reject
                                        </button>
                                    </div>
                                ` : ''}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            // Background check for email status
            applications.forEach(app => checkEmailStatus(app.applicationId));

        } catch (error) {
            console.error(error);
            document.getElementById('applicationsContainer').innerHTML = `<p class="text-center text-red-500 py-10">Error loading data.</p>`;
        }
    }

    // --- Profile Modal ---
    function viewApplicant(applicationId) {
        const appCard = event.currentTarget.closest('.applicant-card');
        const seekerId = appCard.dataset.seekerId;
        
        markAsReviewed(applicationId);
        
        fetch(`/api/profile/seeker/${seekerId}`)
            .then(r => r.json())
            .then(profile => {
                console.log('Profile data:', profile); // Debug log
                const fullName = `${profile.firstName} ${profile.lastName}`;

                // Build skills section
                const skillsHtml = profile.skills?.length ? 
                    profile.skills.map(skillName => `
                        <span style="display: inline-block; background: #E0E7FF; color: #3730A3; padding: 4px 12px; border-radius: 12px; font-size: 12px; margin: 4px;">
                            ${skillName}
                        </span>
                    `).join('') : 
                    '<p style="color: #9CA3AF; font-size: 13px;">No skills listed</p>';

                // Build experience section
                const experienceHtml = profile.experience?.length ?
                    profile.experience.map(exp => `
                        <div style="border-left: 3px solid #6C63FF; padding-left: 12px; margin-bottom: 16px;">
                            <h5 style="font-weight: 600; color: #1C2B53; margin-bottom: 4px;">${exp.jobTitle}</h5>
                            <p style="color: #6B7280; font-size: 13px; margin-bottom: 4px;">
                                <i class="fas fa-building" style="width: 16px;"></i> ${exp.company}
                            </p>
                            ${exp.startDate ? `
                                <p style="color: #9CA3AF; font-size: 12px; margin-bottom: 4px;">
                                    <i class="fas fa-calendar" style="width: 16px;"></i> 
                                    ${new Date(exp.startDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })} - 
                                    ${exp.endDate ? new Date(exp.endDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : 'Present'}
                                </p>
                            ` : ''}
                            ${exp.description ? `<p style="color: #374151; font-size: 13px; margin-top: 8px;">${exp.description}</p>` : ''}
                        </div>
                    `).join('') :
                    '<p style="color: #9CA3AF; font-size: 13px;">No experience listed</p>';

                // Build education section
                const educationHtml = profile.education?.length ?
                    profile.education.map(edu => `
                        <div style="border-left: 3px solid #10B981; padding-left: 12px; margin-bottom: 16px;">
                            <h5 style="font-weight: 600; color: #1C2B53; margin-bottom: 4px;">${edu.degree || 'Degree'}</h5>
                            <p style="color: #6B7280; font-size: 13px; margin-bottom: 4px;">
                                <i class="fas fa-university" style="width: 16px;"></i> ${edu.institution}
                            </p>
                            ${edu.startDate ? `
                                <p style="color: #9CA3AF; font-size: 12px;">
                                    <i class="fas fa-calendar" style="width: 16px;"></i> 
                                    ${new Date(edu.startDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' })} - 
                                    ${edu.endDate ? new Date(edu.endDate).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : 'Present'}
                                </p>
                            ` : ''}
                        </div>
                    `).join('') :
                    '<p style="color: #9CA3AF; font-size: 13px;">No education listed</p>';

                Swal.fire({
                    title: fullName,
                    width: window.innerWidth < 768 ? '95%' : '800px',
                    html: `
                        <div style="text-align: left; max-height: 70vh; overflow-y: auto; padding: 0 8px;">
                            <!-- Profile Header -->
                            <div style="text-align: center; margin-bottom: 24px;">
                                ${profile.selfiePhotoPath ? 
                                    `<img src="${profile.selfiePhotoPath}" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 4px solid #6C63FF; margin: 0 auto;">` : 
                                    `<div style="width: 100px; height: 100px; border-radius: 50%; background: #E0E7FF; display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                                        <i class="fas fa-user" style="font-size: 40px; color: #6C63FF;"></i>
                                    </div>`
                                }
                            </div>

                            <!-- Contact Info -->
                            <div style="background: #F0F4FF; padding: 16px; border-radius: 12px; margin-bottom: 20px;">
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; font-size: 14px;">
                                    <div>
                                        <i class="fas fa-envelope" style="color: #6C63FF; width: 20px;"></i>
                                        <span style="color: #374151;">${profile.email}</span>
                                    </div>
                                    <div>
                                        <i class="fas fa-phone" style="color: #6C63FF; width: 20px;"></i>
                                        <span style="color: #374151;">${profile.phoneNumber || 'N/A'}</span>
                                    </div>
                                    ${profile.address ? `
                                        <div style="grid-column: 1 / -1;">
                                            <i class="fas fa-map-marker-alt" style="color: #6C63FF; width: 20px;"></i>
                                            <span style="color: #374151;">${profile.address}</span>
                                        </div>
                                    ` : ''}
                                </div>
                            </div>

                            <!-- Skills -->
                            <div style="margin-bottom: 20px;">
                                <h4 style="font-weight: 700; color: #1C2B53; font-size: 16px; margin-bottom: 12px; border-bottom: 2px solid #E5E7EB; padding-bottom: 8px;">
                                    <i class="fas fa-star" style="color: #6C63FF;"></i> Skills
                                </h4>
                                <div>${skillsHtml}</div>
                            </div>

                            <!-- Experience -->
                            <div style="margin-bottom: 20px;">
                                <h4 style="font-weight: 700; color: #1C2B53; font-size: 16px; margin-bottom: 12px; border-bottom: 2px solid #E5E7EB; padding-bottom: 8px;">
                                    <i class="fas fa-briefcase" style="color: #6C63FF;"></i> Work Experience
                                </h4>
                                <div>${experienceHtml}</div>
                            </div>

                            <!-- Education -->
                            <div style="margin-bottom: 20px;">
                                <h4 style="font-weight: 700; color: #1C2B53; font-size: 16px; margin-bottom: 12px; border-bottom: 2px solid #E5E7EB; padding-bottom: 8px;">
                                    <i class="fas fa-graduation-cap" style="color: #6C63FF;"></i> Education
                                </h4>
                                <div>${educationHtml}</div>
                            </div>
                        </div>
                    `,
                    confirmButtonText: 'Close',
                    confirmButtonColor: '#1C2B53',
                    customClass: { 
                        htmlContainer: 'swal-html-container',
                        popup: 'swal-wide'
                    }
                });
            })
            .catch(error => {
                console.error('Error loading profile:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to load seeker profile',
                    confirmButtonColor: '#1C2B53'
                });
            });
    }

    // --- Email & Messaging Logic ---
    async function handleEmailButton(email, name, applicationId, receiverId) {
        const text = document.getElementById(`contact-text-${applicationId}`);
        
        // If button shows "Emailed", show email history
        if (text.textContent === 'Emailed') {
            await showEmailHistory(applicationId, name);
        } else {
            // Otherwise, open compose modal
            contactApplicant(email, name, applicationId, receiverId);
        }
    }

    async function showEmailHistory(applicationId, name) {
        try {
            const res = await fetch(`/api/email/application/${applicationId}`);
            if (res.ok) {
                const emails = await res.json();
                if (emails.length > 0) {
                    const emailList = emails.map(e => {
                        const date = new Date(e.sentAt).toLocaleString('en-US', {
                            month: 'short', day: 'numeric', year: 'numeric', 
                            hour: '2-digit', minute: '2-digit'
                        });
                        return `
                            <div style="border-bottom: 1px solid #e5e7eb; padding: 12px 0; text-align: left;">
                                <div style="font-weight: 600; color: #1f2937; margin-bottom: 4px;">${e.subject}</div>
                                <div style="font-size: 13px; color: #6b7280; margin-bottom: 8px;">${date}</div>
                                <div style="font-size: 14px; color: #374151;">${e.message}</div>
                            </div>
                        `;
                    }).join('');

                    Swal.fire({
                        title: `Email History - ${name}`,
                        width: window.innerWidth < 768 ? '95%' : '600px',
                        html: `<div style="max-height: 400px; overflow-y: auto;">${emailList}</div>`,
                        confirmButtonText: 'Close',
                        confirmButtonColor: '#1e1b4b',
                        showCancelButton: true,
                        cancelButtonText: 'Send New Email',
                        cancelButtonColor: '#6C63FF'
                    }).then((result) => {
                        if (result.isDismissed && result.dismiss === Swal.DismissReason.cancel) {
                            // User clicked "Send New Email"
                            const appCard = document.querySelector(`[data-application-id="${applicationId}"]`);
                            const seekerId = appCard.dataset.seekerId;
                            const seekerEmail = emails[0].to;
                            contactApplicant(seekerEmail, name, applicationId, seekerId);
                        }
                    });
                }
            }
        } catch (e) {
            console.error('Error fetching email history:', e);
        }
    }

    function contactApplicant(email, name, applicationId, receiverId) {
        Swal.fire({
            title: `Email ${name}`,
            width: window.innerWidth < 768 ? '95%' : '500px',
            html: `<input type="text" id="emailSubject" class="swal2-input" placeholder="Subject" style="width: 80%">
                   <textarea id="emailMessage" class="swal2-textarea" placeholder="Message" style="width: 80%"></textarea>`,
            showCancelButton: true,
            confirmButtonText: 'Send',
            preConfirm: () => {
                const subject = document.getElementById('emailSubject').value;
                const message = document.getElementById('emailMessage').value;
                if (!subject || !message) return Swal.showValidationMessage('Fill all fields');
                return { subject, message };
            }
        }).then(res => {
            if (res.isConfirmed) sendEmail(email, res.value.subject, res.value.message, applicationId, receiverId);
        });
    }

    async function sendEmail(to, subject, message, applicationId, receiverId) {
        try {
            const res = await fetch('/api/email/send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ to, subject, message, applicationId, receiverId })
            });
            if (res.ok) {
                Swal.fire('Sent!', '', 'success');
                updateContactButton(applicationId, true);
            }
        } catch (e) { Swal.fire('Error', 'Could not send email', 'error'); }
    }

    async function checkEmailStatus(applicationId) {
        const res = await fetch(`/api/email/application/${applicationId}`);
        if (res.ok) {
            const data = await res.json();
            if (data.length > 0) updateContactButton(applicationId, true);
        }
    }

    function updateContactButton(applicationId, hasEmailed) {
        const btn = document.getElementById(`contact-btn-${applicationId}`);
        const text = document.getElementById(`contact-text-${applicationId}`);
        if (btn && hasEmailed) {
            btn.classList.remove('bg-gray-600', 'hover:bg-gray-700');
            btn.classList.add('bg-gray-500', 'hover:bg-gray-600');
            text.textContent = 'Emailed';
        }
    }

    function openMessaging(seekerId, seekerName, applicationId) {
        markAsReviewed(applicationId);
        window.location.href = `/Messages/Index?seekerId=${seekerId}&seekerName=${encodeURIComponent(seekerName)}`;
    }

    // --- Status Updates ---
    async function updateApplicationStatus(id, status) {
        const confirm = await Swal.fire({
            title: `Confirm ${status}?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: status === 'Accepted' ? '#10b981' : '#ef4444'
        });

        if (confirm.isConfirmed) {
            const res = await fetch(`/api/applications/${id}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            if (res.ok) {
                Swal.fire('Updated', '', 'success');
                loadApplications();
            }
        }
    }

    async function markAsReviewed(id) {
        fetch(`/api/applications/${id}/status`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'Reviewed' })
        }).then(() => loadApplications());
    }

    document.addEventListener('DOMContentLoaded', loadApplications);
</script>