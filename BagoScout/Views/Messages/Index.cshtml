@{
    ViewData["Title"] = "Messages";
    ViewData["ActivePage"] = "Messages";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var userId = ViewBag.UserId;
    var userType = ViewBag.UserType;
}

<style>
    .chat-container {
        display: grid;
        grid-template-columns: 350px 1fr;
        height: 100vh;
        background: white;
        overflow: hidden;
        position: fixed;
        top: 0;
        left: 256px;
        right: 0;
        bottom: 0;
    }
    .conversations-list {
        border-right: 2px solid #E5E7EB;
        overflow-y: auto;
        max-height: 100%;
    }
    .chat-area {
        display: flex;
        flex-direction: column;
        height: 100%;
        min-height: 0;
    }
    
    @@media (max-width: 768px) {
        .chat-container {
            left: 0;
            right: 0;
            top: 0;
            bottom: 0;
            position: fixed;
            z-index: 25;
            display: block;
            height: 100vh;
        }
        .conversations-list {
            display: block;
            width: 100%;
            height: 100vh;
            border-right: none;
        }
        .conversations-list.mobile-hide {
            display: none !important;
        }
        .chat-area {
            display: none;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            height: 100vh;
            background: white;
            z-index: 10;
        }
        .chat-area.mobile-show {
            display: flex !important;
        }
        .back-to-conversations {
            display: flex !important;
        }
    }
    .back-to-conversations {
        display: none;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        background: #6C63FF;
        color: white;
        border: none;
        cursor: pointer;
        font-weight: 600;
        width: 100%;
        text-align: left;
    }
    .back-to-conversations:hover {
        background: #5A52D5;
    }
    .conversation-item {
        padding: 16px;
        border-bottom: 1px solid #E5E7EB;
        cursor: pointer;
        transition: all 0.3s;
    }
    .conversation-item:hover {
        background: #F3F4F6;
    }
    .conversation-item.active {
        background: #EEF2FF;
        border-left: 4px solid #6C63FF;
    }
    .chat-header {
        padding: 20px;
        border-bottom: 2px solid #E5E7EB;
        background: #F9FAFB;
        flex-shrink: 0;
    }
    .messages-container {
        flex: 1;
        min-height: 0;
        overflow-y: auto;
        padding: 20px;
        background: #F9FAFB;
    }
    .message {
        margin-bottom: 16px;
        display: flex;
        gap: 12px;
    }
    .message.sent {
        flex-direction: row-reverse;
    }
    .message-bubble {
        max-width: 60%;
        padding: 12px 16px;
        border-radius: 12px;
        word-wrap: break-word;
    }
    .message.received .message-bubble {
        background: white;
        border: 1px solid #E5E7EB;
    }
    .message.sent .message-bubble {
        background: #6C63FF;
        color: white;
    }
    .message-input-area {
        padding: 20px;
        border-top: 2px solid #E5E7EB;
        background: white;
        flex-shrink: 0;
    }
    .unread-badge {
        background: #EF4444;
        color: white;
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: bold;
    }
</style>

<div class="chat-container">
    <!-- Conversations List -->
    <div class="conversations-list">
        <div class="p-4 border-b-2 border-gray-200">
            <h3 class="font-bold text-gray-800">Conversations</h3>
        </div>
        <div id="conversationsList">
            <div class="text-center py-12">
                <i class="fas fa-spinner fa-spin text-2xl text-gray-400"></i>
                <p class="text-gray-600 mt-2">Loading...</p>
            </div>
        </div>
    </div>

    <!-- Chat Area -->
    <div class="chat-area">
        <button class="back-to-conversations" onclick="backToConversations()">
            <i class="fas fa-arrow-left"></i>
            <span>Back to Conversations</span>
        </button>
        <div id="chatHeader" class="chat-header" style="display: none;">
            <div class="flex items-center gap-3">
                <div id="chatUserPhoto" class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center">
                    <i class="fas fa-user text-indigo-600"></i>
                </div>
                <div>
                    <h3 id="chatUserName" class="font-bold text-gray-800"></h3>
                    <p id="chatUserType" class="text-sm text-gray-600"></p>
                </div>
            </div>
        </div>

        <div id="messagesContainer" class="messages-container">
            <div class="text-center py-20">
                <i class="fas fa-comments text-6xl text-gray-300 mb-4"></i>
                <p class="text-gray-600">Select a conversation to start messaging</p>
            </div>
        </div>

        <div id="messageInputArea" class="message-input-area" style="display: none;">
            <div class="flex gap-3">
                <input type="text" id="messageInput" placeholder="Type your message..." 
                       class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-primary-purple"
                       onkeypress="if(event.key === 'Enter') sendMessage()">
                <button onclick="sendMessage()" class="px-6 py-3 bg-primary-purple text-white rounded-lg font-semibold hover:bg-opacity-90 transition">
                    <i class="fas fa-paper-plane mr-2"></i> Send
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const currentUserId = @userId;
    let selectedUserId = null;
    let messagePollingInterval = null;

    // Check if coming from Candidates page with seeker info
    const urlParams = new URLSearchParams(window.location.search);
    const seekerId = urlParams.get('seekerId');
    const seekerName = urlParams.get('seekerName');

    async function loadConversations(silent = false) {
        try {
            const response = await fetch('/api/messages/conversations');
            if (!response.ok) throw new Error('Failed to fetch conversations');
            
            const conversations = await response.json();
            const container = document.getElementById('conversationsList');
            
            if (!conversations || conversations.length === 0) {
                if (!silent) {
                    container.innerHTML = `
                        <div class="text-center py-12 px-4">
                            <i class="fas fa-inbox text-4xl text-gray-300 mb-3"></i>
                            <p class="text-gray-600 text-sm">No conversations yet</p>
                        </div>
                    `;
                    
                    // If coming from Candidates page with no existing conversation, start new one
                    if (seekerId && seekerName) {
                        await selectConversation(parseInt(seekerId), decodeURIComponent(seekerName), '', 'seeker', true);
                    }
                }
                return;
            }

            container.innerHTML = conversations.map(conv => {
                const firstName = conv.firstName.charAt(0).toUpperCase() + conv.firstName.slice(1).toLowerCase();
                const lastName = conv.lastName.charAt(0).toUpperCase() + conv.lastName.slice(1).toLowerCase();
                const fullName = `${firstName} ${lastName}`;
                const lastMessageTime = new Date(conv.lastMessageTime).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                
                return `
                    <div class="conversation-item ${selectedUserId === conv.userId ? 'active' : ''}" data-user-id="${conv.userId}" onclick="selectConversation(${conv.userId}, '${fullName}', '${conv.selfiePhotoPath || ''}', '${conv.userType}')">
                        <div class="flex items-start gap-3">
                            ${conv.selfiePhotoPath ? `
                                <img src="${conv.selfiePhotoPath}" class="w-12 h-12 rounded-full object-cover">
                            ` : `
                                <div class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-user text-indigo-600"></i>
                                </div>
                            `}
                            <div class="flex-1 min-w-0">
                                <div class="flex justify-between items-start">
                                    <h4 class="font-semibold text-gray-800 truncate">${fullName}</h4>
                                    <span class="text-xs text-gray-500">${lastMessageTime}</span>
                                </div>
                                <p class="text-sm text-gray-600 truncate">${conv.lastMessage}</p>
                                ${conv.unreadCount > 0 ? `<span class="unread-badge">${conv.unreadCount}</span>` : ''}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            // If coming from Candidates page and not silent refresh, select that conversation
            if (!silent && seekerId && seekerName) {
                const targetConv = conversations.find(c => c.userId === parseInt(seekerId));
                if (targetConv) {
                    const firstName = targetConv.firstName.charAt(0).toUpperCase() + targetConv.firstName.slice(1).toLowerCase();
                    const lastName = targetConv.lastName.charAt(0).toUpperCase() + targetConv.lastName.slice(1).toLowerCase();
                    const fullName = `${firstName} ${lastName}`;
                    await selectConversation(parseInt(seekerId), fullName, targetConv.selfiePhotoPath || '', targetConv.userType, true);
                } else {
                    await selectConversation(parseInt(seekerId), decodeURIComponent(seekerName), '', 'seeker', true);
                }
            }

        } catch (error) {
            console.error('Error loading conversations:', error);
        }
    }

    async function selectConversation(userId, userName, photoPath, userType, skipEventCheck = false) {
        selectedUserId = userId;
        
        // Mobile: Hide conversations list and show chat area
        if (window.innerWidth <= 768) {
            document.querySelector('.conversations-list').classList.add('mobile-hide');
            document.querySelector('.chat-area').classList.add('mobile-show');
        }
        
        // Update active state
        document.querySelectorAll('.conversation-item').forEach(item => {
            item.classList.remove('active');
        });
        
        if (!skipEventCheck && event) {
            event.target.closest('.conversation-item')?.classList.add('active');
        } else {
            // Find and activate the conversation item
            const convItem = document.querySelector(`[data-user-id="${userId}"]`);
            if (convItem) {
                convItem.classList.add('active');
            }
        }
        
        // Show chat header and input
        document.getElementById('chatHeader').style.display = 'block';
        document.getElementById('messageInputArea').style.display = 'block';
        
        // Update header
        document.getElementById('chatUserName').textContent = userName;
        document.getElementById('chatUserType').textContent = userType === 'employer' ? 'Employer' : 'Job Seeker';
        
        if (photoPath) {
            document.getElementById('chatUserPhoto').innerHTML = `<img src="${photoPath}" class="w-12 h-12 rounded-full object-cover">`;
        } else {
            document.getElementById('chatUserPhoto').innerHTML = `<i class="fas fa-user text-indigo-600"></i>`;
        }
        
        // Load messages
        await loadMessages(userId);
        
        // Start polling for new messages AND conversations
        if (messagePollingInterval) {
            clearInterval(messagePollingInterval);
        }
        messagePollingInterval = setInterval(async () => {
            await loadMessages(userId, true);
            await loadConversations(true); // Refresh conversations list
        }, 3000);
    }
    
    function backToConversations() {
        document.querySelector('.conversations-list').classList.remove('mobile-hide');
        document.querySelector('.chat-area').classList.remove('mobile-show');
        
        // Clear polling
        if (messagePollingInterval) {
            clearInterval(messagePollingInterval);
            messagePollingInterval = null;
        }
    }

    async function loadMessages(userId, silent = false) {
        try {
            const response = await fetch(`/api/messages/${userId}`);
            if (!response.ok) throw new Error('Failed to fetch messages');
            
            const messages = await response.json();
            const container = document.getElementById('messagesContainer');
            
            if (!messages || messages.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-20">
                        <i class="fas fa-comments text-6xl text-gray-300 mb-4"></i>
                        <p class="text-gray-600">No messages yet. Start the conversation!</p>
                    </div>
                `;
                return;
            }

            const shouldScroll = container.scrollHeight - container.scrollTop === container.clientHeight || !silent;

            container.innerHTML = messages.map(msg => {
                const isSent = msg.senderId === currentUserId;
                const messageTime = new Date(msg.sentAt).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
                
                return `
                    <div class="message ${isSent ? 'sent' : 'received'}">
                        <div class="message-bubble">
                            <p class="text-sm">${msg.messageText}</p>
                            <p class="text-xs mt-1 ${isSent ? 'text-purple-200' : 'text-gray-500'}">${messageTime}</p>
                        </div>
                    </div>
                `;
            }).join('');

            if (shouldScroll) {
                container.scrollTop = container.scrollHeight;
            }

        } catch (error) {
            console.error('Error loading messages:', error);
        }
    }

    async function sendMessage() {
        const input = document.getElementById('messageInput');
        const messageText = input.value.trim();
        
        if (!messageText || !selectedUserId) return;
        
        try {
            const response = await fetch('/api/messages/send', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    receiverId: selectedUserId,
                    messageText: messageText
                })
            });

            if (!response.ok) throw new Error('Failed to send message');

            input.value = '';
            await loadMessages(selectedUserId);
            await loadConversations(true); // Refresh conversations list silently

        } catch (error) {
            console.error('Error sending message:', error);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to send message',
                confirmButtonColor: '#1C2B53'
            });
        }
    }

    document.addEventListener('DOMContentLoaded', loadConversations);

    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
        if (messagePollingInterval) {
            clearInterval(messagePollingInterval);
        }
    });
</script>
