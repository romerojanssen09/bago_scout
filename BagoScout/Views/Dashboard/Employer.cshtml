@{
    ViewData["Title"] = "Employer Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: all 0.3s;
    }
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    }
    .action-btn {
        background: #1C2B53;
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }
    .action-btn:hover {
        background: #2C3B63;
        transform: translateY(-2px);
    }
    .job-item {
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 16px;
        transition: all 0.3s;
        cursor: pointer;
    }
    .job-item:hover {
        border-color: #6C63FF;
        box-shadow: 0 4px 12px rgba(108, 99, 255, 0.1);
    }
    .job-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        margin-right: 8px;
    }
    .badge-active {
        background: #D1FAE5;
        color: #065F46;
    }
    .badge-inactive {
        background: #FEE2E2;
        color: #991B1B;
    }
    .job-actions {
        display: flex;
        gap: 8px;
    }
    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        cursor: pointer;
        transition: all 0.3s;
    }
    .btn-edit {
        background: #DBEAFE;
        color: #1E40AF;
    }
    .btn-edit:hover {
        background: #BFDBFE;
    }
    .btn-delete {
        background: #FEE2E2;
        color: #991B1B;
    }
    .btn-delete:hover {
        background: #FECACA;
    }
    .btn-view {
        background: #E0E7FF;
        color: #3730A3;
    }
    .btn-view:hover {
        background: #C7D2FE;
    }

    /* Mobile Responsive */
    @@media (max-width: 768px) {
        .dashboard-header {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 16px;
        }
        .dashboard-header h2 {
            font-size: 24px !important;
        }
        .dashboard-header p {
            font-size: 14px !important;
        }
        .action-btn {
            width: 100%;
            text-align: center;
            padding: 14px 20px;
        }
        .stat-card {
            padding: 16px;
        }
        .stat-card h3 {
            font-size: 24px !important;
        }
        .stat-card .text-sm {
            font-size: 12px !important;
        }
        .job-item {
            padding: 16px;
        }
        .job-item .flex {
            flex-direction: column;
            gap: 12px;
        }
        .job-item h4 {
            font-size: 16px !important;
        }
        .job-item .text-gray-600 {
            font-size: 13px !important;
        }
        .job-item .text-sm {
            font-size: 12px !important;
        }
        .job-actions {
            width: 100%;
            justify-content: flex-end;
        }
        .recent-applicant-item {
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 8px !important;
        }
        .recent-applicant-item > div:first-child {
            width: 40px !important;
            height: 40px !important;
        }
    }
</style>

<!-- Header -->
<div class="mb-8 flex justify-between items-center dashboard-header">
    <div>
        <h2 class="text-3xl font-bold text-gray-800">Welcome back, @ViewBag.UserName! 👋</h2>
        <p class="text-gray-600 mt-2">Manage your job postings and find the perfect candidates</p>
    </div>
    <a href="/Jobs/Manage" class="action-btn">
        <i class="fas fa-plus mr-2"></i> Post New Job
    </a>
</div>

<!-- Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="stat-card">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Active Jobs</p>
                <h3 class="text-3xl font-bold text-gray-800 mt-2" id="activeJobsCount">0</h3>
            </div>
            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                <i class="fas fa-briefcase text-blue-600 text-xl"></i>
            </div>
        </div>
    </div>

    <div class="stat-card">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Total Applicants</p>
                <h3 class="text-3xl font-bold text-gray-800 mt-2">0</h3>
            </div>
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center">
                <i class="fas fa-users text-green-600 text-xl"></i>
            </div>
        </div>
    </div>

    <div class="stat-card">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Interviews</p>
                <h3 class="text-3xl font-bold text-gray-800 mt-2">0</h3>
            </div>
            <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center">
                <i class="fas fa-calendar-check text-purple-600 text-xl"></i>
            </div>
        </div>
    </div>

    <div class="stat-card">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-gray-600 text-sm">Hired</p>
                <h3 class="text-3xl font-bold text-gray-800 mt-2">0</h3>
            </div>
            <div class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center">
                <i class="fas fa-user-check text-orange-600 text-xl"></i>
            </div>
        </div>
    </div>
</div>

<!-- Recent Applicants -->
<div class="stat-card mb-8">
    <div class="flex justify-between items-center mb-4">
        <h3 class="text-xl font-bold text-gray-800">Recent Applicants</h3>
        <a href="/Candidates/Index" class="text-sm text-blue-600 hover:underline">View All</a>
    </div>
    <div id="recentApplicantsContainer">
        <div class="text-center py-12 text-gray-500">
            <i class="fas fa-spinner fa-spin text-4xl mb-4"></i>
            <p>Loading applicants...</p>
        </div>
    </div>
</div>

<!-- Job Postings -->
<div class="stat-card">
    <div class="flex justify-between items-center mb-4">
        <h3 class="text-xl font-bold text-gray-800">Your Job Postings</h3>
        <a href="/Jobs/Manage" class="text-sm text-blue-600 hover:underline">Create New</a>
    </div>
    <div id="jobPostingsContainer">
        <div class="text-center py-12 text-gray-500">
            <i class="fas fa-spinner fa-spin text-4xl mb-4"></i>
            <p>Loading job postings...</p>
        </div>
    </div>
</div>

<script>
    async function loadRecentApplicants() {
        try {
            const response = await fetch('/api/jobs/employer');
            if (!response.ok) throw new Error('Failed to fetch jobs');
            
            const jobs = await response.json();
            const container = document.getElementById('recentApplicantsContainer');
            
            if (!Array.isArray(jobs) || jobs.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-12 text-gray-500">
                        <i class="fas fa-users text-6xl mb-4 opacity-20"></i>
                        <p>No applicants yet</p>
                        <p class="text-sm mt-2">Post jobs to start receiving applications</p>
                    </div>
                `;
                return;
            }

            // Fetch applications for all jobs
            const allApplications = [];
            for (const job of jobs) {
                try {
                    const appResponse = await fetch(`/api/jobs/${job.jobId}/applications`);
                    if (appResponse.ok) {
                        const apps = await appResponse.json();
                        apps.forEach(app => {
                            app.jobTitle = job.title;
                            allApplications.push(app);
                        });
                    }
                } catch (err) {
                    console.error(`Error fetching applications for job ${job.jobId}:`, err);
                }
            }

            if (allApplications.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-12 text-gray-500">
                        <i class="fas fa-users text-6xl mb-4 opacity-20"></i>
                        <p>No applicants yet</p>
                        <p class="text-sm mt-2">Post jobs to start receiving applications</p>
                    </div>
                `;
                return;
            }

            // Sort by date and take top 5
            allApplications.sort((a, b) => new Date(b.appliedAt) - new Date(a.appliedAt));
            const recentApps = allApplications.slice(0, 5);

            container.innerHTML = recentApps.map(app => {
                const appliedDate = new Date(app.appliedAt).toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });

                return `
                    <div class="recent-applicant-item" style="border-bottom: 1px solid #E5E7EB; padding: 16px 0; display: flex; align-items: center; gap: 12px;">
                        <div style="width: 48px; height: 48px; border-radius: 50%; background: #E0E7FF; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                            <i class="fas fa-user text-indigo-600 text-xl"></i>
                        </div>
                        <div style="flex: 1; min-width: 0;">
                            <h4 style="font-weight: 600; color: #1C2B53; margin-bottom: 4px;">${app.seekerName}</h4>
                            <p style="font-size: 13px; color: #6B7280; margin-bottom: 2px;">Applied for: ${app.jobTitle}</p>
                            <p style="font-size: 12px; color: #9CA3AF;">${appliedDate}</p>
                        </div>
                        <span style="padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600; background: #FEF3C7; color: #92400E; flex-shrink: 0;">
                            ${app.status}
                        </span>
                    </div>
                `;
            }).join('');

        } catch (error) {
            console.error('Error loading applicants:', error);
            document.getElementById('recentApplicantsContainer').innerHTML = `
                <div class="text-center py-12 text-gray-500">
                    <i class="fas fa-exclamation-circle text-6xl mb-4 opacity-20"></i>
                    <p>Failed to load applicants</p>
                </div>
            `;
        }
    }

    async function loadJobPostings() {
        try {
            const response = await fetch('/api/jobs/employer');
            
            if (!response.ok) {
                throw new Error('Failed to fetch jobs');
            }
            
            const jobs = await response.json();
            const container = document.getElementById('jobPostingsContainer');
            
            if (!Array.isArray(jobs) || jobs.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-12 text-gray-500">
                        <i class="fas fa-briefcase text-6xl mb-4 opacity-20"></i>
                        <p>No job postings yet</p>
                        <p class="text-sm mt-2">Create your first job posting to start receiving applications</p>
                        <a href="/Jobs/Manage" class="action-btn mt-4">
                            <i class="fas fa-plus mr-2"></i> Create Job Posting
                        </a>
                    </div>
                `;
                document.getElementById('activeJobsCount').textContent = '0';
                return;
            }

            // Update active jobs count
            const activeCount = jobs.filter(j => j.isActive).length;
            document.getElementById('activeJobsCount').textContent = activeCount;

            // Display jobs
            container.innerHTML = jobs.map(job => {
                const createdDate = new Date(job.createdAt).toLocaleDateString('en-US', { 
                    year: 'numeric', 
                    month: 'short', 
                    day: 'numeric' 
                });

                return `
                    <div class="job-item">
                        <div class="flex justify-between items-start">
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-2">
                                    <h4 class="text-lg font-bold text-gray-800">${job.title}</h4>
                                    <span class="job-badge ${job.isActive ? 'badge-active' : 'badge-inactive'}">
                                        ${job.isActive ? 'Active' : 'Inactive'}
                                    </span>
                                </div>
                                <p class="text-gray-600 mb-2">
                                    <i class="fas fa-building mr-2"></i>${job.company}
                                </p>
                                <p class="text-gray-600 mb-2">
                                    <i class="fas fa-map-marker-alt mr-2"></i>${job.address}
                                </p>
                                <div class="flex gap-4 text-sm text-gray-500 mb-2">
                                    ${job.jobType ? `<span><i class="fas fa-briefcase mr-1"></i>${job.jobType}</span>` : ''}
                                    ${job.salaryRange ? `<span><i class="fas fa-money-bill-wave mr-1"></i>${job.salaryRange}</span>` : ''}
                                    ${job.experienceLevel ? `<span><i class="fas fa-chart-line mr-1"></i>${job.experienceLevel}</span>` : ''}
                                </div>
                                <p class="text-sm text-gray-500">
                                    <i class="fas fa-calendar mr-1"></i>Posted on ${createdDate}
                                </p>
                            </div>
                            <div class="job-actions">
                                <button class="btn-icon btn-view" onclick="viewJob(${job.jobId})" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </button>
                                <button class="btn-icon btn-edit" onclick="editJob(${job.jobId})" title="Edit">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn-icon btn-delete" onclick="deleteJob(${job.jobId})" title="Delete">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

        } catch (error) {
            console.error('Error loading jobs:', error);
            document.getElementById('jobPostingsContainer').innerHTML = `
                <div class="text-center py-12 text-gray-500">
                    <i class="fas fa-exclamation-circle text-6xl mb-4 opacity-20"></i>
                    <p>Failed to load job postings</p>
                    <p class="text-sm mt-2">Please try refreshing the page</p>
                </div>
            `;
        }
    }

    async function viewJob(jobId) {
        try {
            const response = await fetch(`/api/jobs/${jobId}`);
            const job = await response.json();

            Swal.fire({
                title: job.title,
                html: `
                    <div style="text-align: left;">
                        <p style="color: #6C63FF; font-weight: 600; margin-bottom: 12px;">
                            <i class="fas fa-building"></i> ${job.company}
                        </p>
                        <p style="margin-bottom: 8px;">
                            <i class="fas fa-map-marker-alt"></i> ${job.address}
                        </p>
                        ${job.salaryRange ? `<p style="margin-bottom: 8px;"><i class="fas fa-money-bill-wave"></i> ${job.salaryRange}</p>` : ''}
                        ${job.jobType ? `<p style="margin-bottom: 8px;"><i class="fas fa-briefcase"></i> ${job.jobType}</p>` : ''}
                        ${job.experienceLevel ? `<p style="margin-bottom: 8px;"><i class="fas fa-chart-line"></i> ${job.experienceLevel}</p>` : ''}
                        <hr style="margin: 16px 0;">
                        <h4 style="color: #1C2B53; font-weight: 600; margin-bottom: 8px;">Description</h4>
                        <p style="color: #374151; margin-bottom: 16px;">${job.description}</p>
                        ${job.requirements ? `
                            <h4 style="color: #1C2B53; font-weight: 600; margin-bottom: 8px;">Requirements</h4>
                            <p style="color: #374151;">${job.requirements}</p>
                        ` : ''}
                    </div>
                `,
                width: 600,
                confirmButtonText: 'Close',
                confirmButtonColor: '#1C2B53'
            });
        } catch (error) {
            console.error('Error viewing job:', error);
        }
    }

    function editJob(jobId) {
        window.location.href = `/Jobs/Manage?jobId=${jobId}`;
    }

    async function deleteJob(jobId) {
        const result = await Swal.fire({
            title: 'Delete Job Posting?',
            text: 'This action cannot be undone. The job will be removed from the platform.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#991B1B',
            cancelButtonColor: '#6B7280',
            confirmButtonText: 'Yes, delete it',
            cancelButtonText: 'Cancel'
        });

        if (result.isConfirmed) {
            try {
                const response = await fetch(`/api/jobs/delete/${jobId}`, {
                    method: 'DELETE'
                });

                if (response.ok) {
                    await Swal.fire({
                        icon: 'success',
                        title: 'Deleted!',
                        text: 'Job posting has been deleted.',
                        confirmButtonColor: '#1C2B53'
                    });
                    loadJobPostings(); // Reload the list
                } else {
                    throw new Error('Failed to delete');
                }
            } catch (error) {
                console.error('Error deleting job:', error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Failed to delete job posting',
                    confirmButtonColor: '#1C2B53'
                });
            }
        }
    }

    // Load jobs when page loads
    document.addEventListener('DOMContentLoaded', () => {
        loadJobPostings();
        loadRecentApplicants();
    });
</script>
